    if (!text.trim()) return true;
    const offTopic = ['wetter', 'weather', 'fußball', 'fussball', 'football', 'politik', 'politics', 'rezept', 'recipe', 'witz', 'joke', 'aktien', 'stock price', 'lotto', 'horoskop', 'horoscope'];
