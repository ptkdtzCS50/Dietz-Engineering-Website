/* =========================================================
   TECHNICAL DEPTH VISUALS
   ========================================================= */
.hero {
  background:
    radial-gradient(circle at 82% 18%, var(--accent-dim), transparent 34rem),
    linear-gradient(180deg, var(--bg) 0%, color-mix(in srgb, var(--bg-2) 42%, var(--bg)) 100%);
}
.hero-bg {
  display: block;
  position: absolute;
  inset: 0;
  opacity: 0.16;
  pointer-events: none;
  mix-blend-mode: multiply;
}
[data-theme="dark"] .hero-bg { opacity: 0.22; mix-blend-mode: screen; }
.hero-bg svg { width: 100%; height: 100%; }
.hero-proof {
  isolation: isolate;
  background:
    linear-gradient(135deg, color-mix(in srgb, var(--bg-card) 92%, transparent), color-mix(in srgb, var(--bg-2) 96%, transparent)),
    linear-gradient(90deg, transparent 0 31px, var(--grid) 31px 32px),
    linear-gradient(0deg, transparent 0 31px, var(--grid) 31px 32px);
  background-size: auto, 32px 32px, 32px 32px;
}
.hero-proof::after {
  content: '';
  position: absolute;
  inset: 0;
  border: 1px solid transparent;
  background: linear-gradient(135deg, var(--accent-line), transparent 34%, var(--border)) border-box;
  mask: linear-gradient(#000 0 0) padding-box, linear-gradient(#000 0 0);
  mask-composite: exclude;
  pointer-events: none;
  opacity: 0.75;
  z-index: -1;
}
.engineering-visual {
  position: relative;
  min-height: 244px;
  margin: -0.25rem -0.25rem 1.35rem;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--bg) 82%, var(--accent-dim));
  overflow: hidden;
}
.engineering-visual::before {
  content: 'PROJECT / DIETZ-E-042 · EPLAN QUALITY GATE';
  position: absolute;
  left: 1rem;
  top: 0.85rem;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.11em;
  color: var(--text-mute);
  z-index: 2;
}
.engineering-visual svg { width: 100%; height: 244px; color: var(--accent); }
.signal-path { stroke-dasharray: 8 14; animation: flow 9s linear infinite; }
.signal-path.slow { animation-duration: 13s; animation-direction: reverse; }
.signal-node { animation: node-pulse 3.8s ease-in-out infinite; transform-origin: center; }
.signal-node:nth-of-type(2n) { animation-delay: 0.8s; }
.scan-line {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 52px;
  left: -60px;
  background: linear-gradient(90deg, transparent, var(--accent-dim), transparent);
  animation: scan-panel 7s ease-in-out infinite;
  pointer-events: none;
}
@keyframes scan-panel {
  0%, 16% { transform: translateX(0); opacity: 0; }
  28%, 68% { opacity: 1; }
  84%, 100% { transform: translateX(460px); opacity: 0; }
}
.visual-status-row {
  position: absolute;
  left: 1rem;
  right: 1rem;
  bottom: 0.9rem;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.45rem;
}
.visual-status {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.58rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent);
  border: 1px solid var(--accent-line);
  background: color-mix(in srgb, var(--bg-card) 84%, var(--accent-dim));
  padding: 0.42rem 0.45rem;
  text-align: center;
}
.handover-section {
  padding: 6rem 0;
  background:
    linear-gradient(90deg, transparent 0 39px, var(--grid) 39px 40px),
    linear-gradient(0deg, transparent 0 39px, var(--grid) 39px 40px),
    var(--bg);
  border-bottom: 1px solid var(--border);
}
.handover-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
  gap: clamp(2rem, 5vw, 4rem);
  align-items: center;
}
.handover-text .section-subtitle { margin-bottom: 1.8rem; }
.check-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
}
.check-tags span {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.72rem;
  color: var(--accent);
  background: var(--accent-dim);
  border: 1px solid var(--accent-line);
  padding: 0.42rem 0.62rem;
}
.handover-board {
  position: relative;
  min-height: 470px;
  border: 1px solid var(--border-strong);
  background: linear-gradient(135deg, var(--bg-2), var(--bg-card));
  box-shadow: var(--shadow);
  overflow: hidden;
}
.handover-board::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(90deg, transparent 0 23px, var(--grid) 23px 24px),
    linear-gradient(0deg, transparent 0 23px, var(--grid) 23px 24px);
  background-size: 24px 24px;
  opacity: 0.8;
}
.doc-stack {
  position: absolute;
  inset: 1.4rem auto auto 1.4rem;
  width: min(55%, 310px);
  height: 330px;
}
.doc-card {
  position: absolute;
  width: 100%;
  min-height: 150px;
  background: var(--bg);
  border: 1px solid var(--border-strong);
  box-shadow: 0 18px 36px rgba(30, 44, 71, 0.12);
  padding: 0.9rem;
  transform: translate(var(--x), var(--y)) rotate(var(--r));
}
.doc-card:nth-child(1) { --x: 0px; --y: 0px; --r: -2deg; }
.doc-card:nth-child(2) { --x: 22px; --y: 82px; --r: 1.4deg; }
.doc-card:nth-child(3) { --x: 44px; --y: 164px; --r: -0.8deg; }
.doc-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid var(--border);
  padding-bottom: 0.45rem;
  margin-bottom: 0.7rem;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.62rem;
  color: var(--text-mute);
}
.doc-title { color: var(--accent); font-weight: 700; }
.schematic-lines {
  display: grid;
  gap: 0.42rem;
  margin-top: 0.6rem;
}
.schematic-lines i {
  display: block;
  height: 1px;
  background: linear-gradient(90deg, var(--accent), var(--accent-line), transparent);
}
.schematic-lines i:nth-child(2) { width: 82%; }
.schematic-lines i:nth-child(3) { width: 62%; }
.schematic-lines i:nth-child(4) { width: 74%; }
.terminal-row {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 2px;
  margin-top: 0.85rem;
}
.terminal-row i { height: 26px; border: 1px solid var(--accent-line); background: var(--accent-dim); }
.bom-row {
  display: grid;
  grid-template-columns: 0.8fr 1.4fr 0.6fr;
  gap: 0.45rem;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.58rem;
  color: var(--text-soft);
  border-bottom: 1px solid var(--border);
  padding: 0.32rem 0;
}
.review-panel {
  position: absolute;
  right: 1.35rem;
  top: 1.4rem;
  bottom: 1.4rem;
  width: min(42%, 270px);
  border: 1px solid var(--border-strong);
  background: color-mix(in srgb, var(--bg-card) 92%, transparent);
  backdrop-filter: blur(14px);
  padding: 1rem;
}
.review-panel h3 {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.76rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 0.95rem;
}
.review-item {
  display: grid;
  grid-template-columns: 72px 1fr;
  gap: 0.7rem;
  align-items: start;
  padding: 0.72rem 0;
  border-top: 1px solid var(--border);
  font-size: 0.82rem;
  color: var(--text-soft);
}
.review-item:first-of-type { border-top: 0; }
.review-state {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.09em;
  color: var(--accent);
  border: 1px solid var(--accent-line);
  background: var(--accent-dim);
  padding: 0.22rem 0.32rem;
  text-align: center;
}
.review-state.warn { color: #9a6a16; border-color: rgba(154,106,22,.34); background: rgba(154,106,22,.08); }
[data-theme="dark"] .review-state.warn { color: #f2b95d; border-color: rgba(242,185,93,.34); background: rgba(242,185,93,.10); }
.handover-flow {
  position: absolute;
  left: 1.4rem;
  right: 1.4rem;
  bottom: 1rem;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 0.5rem;
}
.handover-flow span {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.58rem;
  text-align: center;
  color: var(--text-mute);
  border-top: 1px solid var(--accent-line);
  padding-top: 0.45rem;
}
.situation-card::after {
  content: '';
  position: absolute;
  left: 1.45rem;
  right: 1.45rem;
  bottom: 4.35rem;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--accent-line), transparent);
  opacity: 0.7;
}
@media (max-width: 980px) {
  .visual-status-row { grid-template-columns: repeat(2, 1fr); }
  .handover-grid { grid-template-columns: 1fr; }
  .handover-board { min-height: 520px; }
}
@media (max-width: 680px) {
  .engineering-visual { min-height: 220px; }
  .engineering-visual svg { height: 220px; }
  .handover-board { min-height: 720px; }
  .doc-stack { width: calc(100% - 2.8rem); }
  .review-panel { left: 1.4rem; right: 1.4rem; top: 390px; bottom: auto; width: auto; }
  .handover-flow { grid-template-columns: repeat(2, 1fr); }
}
@media (prefers-reduced-motion: reduce) {
  .signal-path,
  .scan-line,
  .hero-bg svg circle,
  .signal-node,
  .flow-line { animation: none !important; }
}

/* =========================================================
   TRUST BAND
   ========================================================= */
.trust-section {
  padding: 4rem 0;
  border-bottom: 1px solid var(--border);
  background: var(--bg);
}
.trust-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem 2.5rem;
}
.trust-block { display: flex; flex-direction: column; gap: 0.7rem; }
.trust-label {
  font-family: 'Inter', sans-serif;
  font-size: 0.74rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--accent);
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
}
.trust-label::before {
  content: '';
  width: 18px; height: 2px;
  background: var(--accent);
}
.trust-text {
  font-size: 0.98rem;
  color: var(--text);
  font-weight: 500;
  line-height: 1.5;
}
@media (max-width: 960px) {
  .trust-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 580px) {
  .trust-grid { grid-template-columns: 1fr; gap: 1.2rem; }
  .trust-section { padding: 2rem 0; }
}
/* =========================================================
   PROJECT SITUATIONS
   ========================================================= */
.situations-section {
  padding: 5.5rem 0;
  background:
    linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 100%);
  border-bottom: 1px solid var(--border);
}
.situations-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
  margin-top: 2.4rem;
}
.situation-card {
  position: relative;
  min-height: 260px;
  padding: 1.45rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}
.situation-card::before {
  content: attr(data-index);
  position: absolute;
  right: 1rem;
  top: 0.75rem;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.78rem;
  color: var(--accent);
  opacity: 0.65;
}
.situation-card h3 {
  font-size: 1.08rem;
  margin: 1.2rem 0 0.8rem;
}
.situation-card p {
  color: var(--text-soft);
  font-size: 0.95rem;
  line-height: 1.65;
}
.situation-signal {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent);
}
.situation-result {
  margin-top: 1.4rem;
  padding-top: 1rem;
  border-top: 1px solid var(--border);
  color: var(--text);
  font-size: 0.9rem;
  font-weight: 700;
}
@media (max-width: 1050px) {
  .situations-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .situations-section { padding: 4rem 0; }
  .situations-grid { grid-template-columns: 1fr; }
  .situation-card { min-height: auto; }
}

html[lang="es"] .section-label,
html[lang="es"] .hero-badge,
html[lang="es"] .hero-proof-label,
html[lang="es"] .trust-label,
html[lang="es"] .stat-label,
html[lang="es"] .show-tag,
html[lang="es"] .service-num,
html[lang="es"] .field-label,
html[lang="es"] .assistant-kicker {
  text-transform: none;
  letter-spacing: 0.035em;
}

html[lang="es"] .hero-proof-label,
html[lang="es"] .stat-label,
html[lang="es"] .trust-label {
  font-weight: 600;
}

/* =========================================================
   ABOUT
   ========================================================= */
.about-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 4rem;
  align-items: start;
}
.about-text p {
  color: var(--text-soft);
  margin-bottom: 1.2rem;
  font-size: 1.02rem;
}

.about-portrait {
  position: relative;
  display: flex;
  flex-direction: column;
}
.about-portrait-frame {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  background: linear-gradient(135deg, #f6f7f9 0%, #ffffff 100%);
  border: 1px solid var(--border);
  overflow: hidden;
}
.about-portrait-frame::before {
  content: '';
  position: absolute;
  top: -1px; left: -1px;
  width: 60px; height: 4px;
  background: var(--accent);
  z-index: 2;
}
.about-portrait-frame img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transition: transform 0.6s cubic-bezier(.2, .8, .2, 1);
}
.about-portrait-frame:hover img { transform: scale(1.03); }
.about-portrait-caption {
  margin-top: 1.4rem;
  padding-left: 1.4rem;
  border-left: 3px solid var(--accent);
}
.about-portrait-name {
  font-size: 1.15rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--text);
  margin-bottom: 0.2rem;
}
.about-portrait-role {
  font-size: 0.88rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--accent);
}
@media (max-width: 760px) {
  .about-portrait-frame { aspect-ratio: 4 / 5; max-width: 420px; margin: 0 auto; }
  .about-portrait-caption { max-width: 420px; margin-left: auto; margin-right: auto; }
}

.usp-quote {
  border-left: 2px solid var(--accent);
  padding: 0.5rem 0 0.5rem 1.4rem;
  margin: 2rem 0;
  font-family: 'Inter', sans-serif;
  font-style: italic;
  font-size: 1.15rem;
  color: var(--text);
  font-weight: 500;
  line-height: 1.4;
}

.travel-note {
  display: flex;
  gap: 0.9rem;
  align-items: flex-start;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 1.1rem 1.3rem;
  margin-top: 2rem;
}
.travel-note .icon {
  color: var(--accent);
  flex-shrink: 0;
  margin-top: 2px;
}
.travel-note p { font-size: 0.92rem; color: var(--text-soft); margin: 0; }
.travel-note strong { color: var(--text); display: block; margin-bottom: 0.2rem; }

.credential-strip {
  display: grid;
  gap: 0.8rem;
  margin: 1.4rem 0 0.2rem;
}
.credential-item {
  display: flex;
  gap: 0.8rem;
  align-items: flex-start;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 0.9rem 1rem;
}
.credential-year {
  flex: 0 0 auto;
  min-width: 4.4rem;
  font-family: 'Inter', sans-serif;
  font-size: 0.76rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent);
  padding-top: 0.1rem;
}
.credential-item strong { display: block; color: var(--text); font-size: 0.96rem; margin-bottom: 0.12rem; }
.credential-item span:last-child { color: var(--text-soft); font-size: 0.88rem; line-height: 1.45; }

.progressive-disclosure {
  margin-top: 1.5rem;
  border: 1px solid var(--border);
  background: var(--bg-2);
  border-radius: 4px;
  overflow: hidden;
}
.progressive-disclosure summary {
  cursor: pointer;
  list-style: none;
  padding: 1rem 1.2rem;
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  color: var(--accent);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}
.progressive-disclosure summary::-webkit-details-marker { display: none; }
.progressive-disclosure summary::after {
  content: '+';
  font-size: 1.25rem;
  line-height: 1;
  color: var(--text-soft);
}
.progressive-disclosure[open] summary::after { content: '–'; }
.progressive-disclosure .proj-grid,
.progressive-disclosure .faq-list {
  padding: 0 1.2rem 1.2rem;
}
.progressive-disclosure .faq-list { margin: 0; }
@media (max-width: 760px) {
  .credential-item { flex-direction: column; gap: 0.35rem; }
  .credential-year { min-width: 0; }
}

.stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}
.stat {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 1.5rem 1.3rem;
  position: relative;
  overflow: hidden;
  transition: border-color 0.2s ease, transform 0.2s ease;
}
.stat:hover {
  border-color: var(--accent-line);
  transform: translateY(-3px);
}
.stat::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 24px; height: 24px;
  border-top: 1px solid var(--accent);
  border-left: 1px solid var(--accent);
  border-radius: 4px 0 0 0;
}
.stat-num {
  font-family: 'Inter', sans-serif;
  font-size: 2.1rem;
  font-weight: 700;
  color: var(--accent);
  line-height: 1;
  margin-bottom: 0.5rem;
}
.stat-label {
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-soft);
}

/* =========================================================
   EDUCATION
   ========================================================= */
.edu-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}
.edu-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 2rem;
  transition: border-color 0.2s ease, transform 0.2s ease;
}
.edu-card:hover {
  border-color: var(--accent-line);
  transform: translateY(-3px);
}
.edu-period {
  font-family: 'Inter', sans-serif;
  font-size: 0.82rem;
  color: var(--accent);
  letter-spacing: 0.06em;
  margin-bottom: 0.8rem;
}
.edu-card h3 {
  font-size: 1.3rem;
  margin-bottom: 0.6rem;
}
.edu-card p { color: var(--text-soft); font-size: 0.95rem; }

/* =========================================================
   SERVICES
   ========================================================= */
.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.4rem;
}
.services-grid-4 {
  grid-template-columns: repeat(4, 1fr);
}
@media (max-width: 1100px) {
  .services-grid-4 { grid-template-columns: repeat(2, 1fr); }
}
.service-card {
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: 0;
  padding: 2rem 1.8rem 1.8rem;
  transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}
.service-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 0; height: 3px;
  background: var(--accent);
  transition: width 0.35s ease;
}
.service-card:hover {
  border-color: var(--accent-line);
  transform: translateY(-6px);
  box-shadow: 0 18px 40px rgba(30, 44, 71, 0.10);
}
.service-card:hover::before { width: 100%; }
.service-num {
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--accent);
  margin-bottom: 1.4rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}
.service-card h3 {
  font-size: 1.3rem;
  font-weight: 700;
  margin-bottom: 0.9rem;
  letter-spacing: -0.02em;
  line-height: 1.25;
}
.service-card p {
  color: var(--text-soft);
  font-size: 0.95rem;
  line-height: 1.6;
  margin-bottom: 1.6rem;
  flex-grow: 1;
}
.service-price {
  font-family: 'Inter', sans-serif;
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--accent);
  padding-top: 1rem;
  border-top: 1px solid var(--border);
  letter-spacing: 0.02em;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}
.service-price::after {
  content: '→';
  transition: transform 0.25s ease;
  font-weight: 700;
}
.service-card:hover .service-price::after { transform: translateX(6px); }

/* =========================================================
   STATS BAND (ABB-style metrics)
   ========================================================= */
.stats-band {
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  background: var(--bg-2);
  padding: 4.8rem 0 4rem;
}
.stats-band .container { max-width: 1400px; padding: 0 2rem; }
.stats-intro,
.trust-intro {
  max-width: 760px;
  margin-bottom: 2.6rem;
}
.stats-intro .section-subtitle,
.trust-intro .section-subtitle {
  margin-bottom: 0;
}
.trust-intro {
  margin-bottom: 2.4rem;
}
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}
@media (max-width: 900px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 520px) { .stats-grid { grid-template-columns: 1fr; } }
.stat-cell {
  padding: 0.5rem 2rem;
  border-left: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
.stat-cell:first-child { border-left: none; padding-left: 0; }
@media (max-width: 900px) {
  .stat-cell:nth-child(3) { border-left: none; padding-left: 0; }
  .stat-cell { padding: 0.5rem 1.5rem; margin-bottom: 1.5rem; }
  .stat-cell:first-child { padding-left: 0; }
}
@media (max-width: 520px) {
  .stat-cell { border-left: none; padding-left: 0; padding-right: 0; }
}
.stat-value {
  font-size: clamp(2.4rem, 4vw, 3.6rem);
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1;
  color: var(--accent);
}
.stat-value sup {
  font-size: 0.55em;
  font-weight: 700;
  vertical-align: super;
  margin-left: 0.1em;
  color: var(--accent);
}
.stat-label {
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--text-soft);
  line-height: 1.4;
}

/* =========================================================
   HERO BANNER (Title image)
   ========================================================= */
.hero-banner {
  position: relative;
  width: 100%;
  margin-top: 70px;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  overflow: hidden;
  display: flex;
  justify-content: center;
}
.hero-banner img {
  display: block;
  width: min(100%, 2172px);
  height: auto;
  max-height: none;
  object-fit: contain;
  object-position: center;
}
.hero-banner:hover img { transform: none; }
@media (max-width: 760px) {
  /* Auf Mobile das volle Banner zeigen, nicht beschneiden */
  .hero-banner img { max-height: none; height: auto; object-fit: contain; }
}
[data-theme="dark"] .hero-banner {
  background: linear-gradient(180deg, #111418 0%, var(--bg) 100%);
}
[data-theme="dark"] .hero-banner img {
  filter: brightness(0.85);
}

/* =========================================================
   SHOWCASE / EINBLICKE
   ========================================================= */
.showcase-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.4rem;
}
@media (max-width: 1100px) {
  .showcase-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 580px) {
  .showcase-grid { grid-template-columns: 1fr; }
}
.show-card {
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  position: relative;
  cursor: pointer;
}
.show-card:hover {
  border-color: var(--accent-line);
  transform: translateY(-6px);
  box-shadow: 0 18px 40px rgba(30, 44, 71, 0.10);
}
.show-visual {
  position: relative;
  aspect-ratio: 4 / 3;
  background: linear-gradient(135deg, #f6f7f9 0%, #ffffff 100%);
  border-bottom: 1px solid var(--border);
  overflow: hidden;
  display: grid;
  place-items: center;
}
.show-visual::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 60%, rgba(30, 44, 71, 0.03) 100%);
  pointer-events: none;
}
.show-visual svg {
  width: 84%;
  height: 84%;
  display: block;
  transition: transform 0.5s cubic-bezier(.2, .8, .2, 1);
}
.show-card:hover .show-visual svg { transform: scale(1.06); }
.show-visual img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(.2, .8, .2, 1);
}
.show-card:hover .show-visual img { transform: scale(1.05); }

/* About-Akzent: Foto-Banner unter dem Fließtext */
.about-accent {
  margin: 1.8rem 0 1.4rem;
  border: 1px solid var(--border);
  overflow: hidden;
  position: relative;
  background: var(--bg-2);
}
.about-accent img {
  width: 100%;
  height: auto;
  display: block;
  aspect-ratio: 16 / 9;
  object-fit: cover;
}
.about-accent figcaption {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 0.85rem 1.1rem;
  font-family: 'Inter', sans-serif;
  font-size: 0.85rem;
  color: #ffffff;
  background: linear-gradient(0deg, rgba(30, 44, 71, 0.88) 0%, rgba(30, 44, 71, 0.55) 60%, rgba(30, 44, 71, 0) 100%);
  letter-spacing: 0.01em;
}
.show-body {
  padding: 1.6rem 1.6rem 1.8rem;
  display: flex;
  flex-direction: column;
  flex-grow: 1;
}
.show-tag {
  font-family: 'Inter', sans-serif;
  font-size: 0.74rem;
  font-weight: 600;
  color: var(--accent);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: 0.8rem;
}
.show-card h3 {
  font-size: 1.2rem;
  font-weight: 700;
  margin-bottom: 0.7rem;
  letter-spacing: -0.02em;
  line-height: 1.3;
}
.show-card p {
  font-size: 0.94rem;
  color: var(--text-soft);
  line-height: 1.6;
  margin-bottom: 1.2rem;
  flex-grow: 1;
}
.show-link {
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--accent);
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  letter-spacing: 0.02em;
}
.show-link::after {
  content: '→';
  transition: transform 0.25s ease;
  font-weight: 700;
}
.show-card:hover .show-link::after { transform: translateX(6px); }

/* =========================================================
   EXPERIENCE TIMELINE
   ========================================================= */
.timeline {
  position: relative;
  max-width: 880px;
  margin: 0 auto;
  padding-left: 2.2rem;
}
.timeline::before {
  content: '';
  position: absolute;
  left: 7px; top: 8px; bottom: 8px;
  width: 1px;
  background: linear-gradient(to bottom, var(--accent) 0%, var(--border) 100%);
}
.tl-item {
  position: relative;
  margin-bottom: 3rem;
}
.tl-item::before {
  content: '';
  position: absolute;
  left: -2.2rem;
  top: 8px;
  width: 15px; height: 15px;
  border-radius: 50%;
  background: var(--bg);
  border: 2px solid var(--accent);
  box-shadow: 0 0 0 4px var(--bg);
}
.tl-period {
  font-family: 'Inter', sans-serif;
  font-size: 0.82rem;
  color: var(--accent);
  letter-spacing: 0.08em;
  margin-bottom: 0.4rem;
}
.tl-item h3 {
  font-size: 1.35rem;
  margin-bottom: 0.3rem;
}
.tl-company {
  color: var(--text-soft);
  font-size: 0.95rem;
  margin-bottom: 1rem;
}
.tl-item ul {
  list-style: none;
  margin-bottom: 1.2rem;
}
.tl-item ul li {
  position: relative;
  padding-left: 1.4rem;
  margin-bottom: 0.5rem;
  color: var(--text-soft);
  font-size: 0.95rem;
}
.tl-item ul li::before {
  content: '▸';
  position: absolute;
  left: 0;
  color: var(--accent);
}
.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 0.8rem;
}
.tag {
  font-family: 'Inter', sans-serif;
  font-size: 0.72rem;
  padding: 0.3rem 0.7rem;
  background: var(--accent-dim);
  border: 1px solid var(--accent-line);
  color: var(--accent);
  border-radius: 6px;
  letter-spacing: 0.04em;
}

/* =========================================================
   SKILLS
   ========================================================= */
.skills-wrapper {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 3rem;
}
.skill-bars { display: flex; flex-direction: column; gap: 1.3rem; }
.skill-bar-item .label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 0.5rem;
  font-size: 0.92rem;
}
.skill-bar-item .label-row .lvl {
  font-family: 'Inter', sans-serif;
  color: var(--accent);
  font-size: 0.8rem;
}
.bar-track {
  height: 6px;
  background: var(--bg-3);
  border: 1px solid var(--border);
  border-radius: 4px;
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent) 0%, var(--accent-soft) 100%);
  border-radius: 4px;
  width: 0;
  transition: width 1.2s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.tools-block { display: flex; flex-direction: column; gap: 2rem; }
.tools-group h4 {
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 1rem;
  font-weight: 500;
}
.pill-list {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.pill {
  font-size: 0.85rem;
  padding: 0.5rem 1rem;
  background: var(--bg-card);
  border: 1px solid var(--border-strong);
  border-radius: 999px;
  color: var(--text-soft);
  transition: border-color 0.2s ease, color 0.2s ease;
}
.pill:hover {
  border-color: var(--accent);
  color: var(--accent);
}

/* =========================================================
   RESULTS
   ========================================================= */
.results-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.4rem;
}
.result-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 2rem 1.8rem;
  transition: border-color 0.25s ease, transform 0.25s ease;
  position: relative;
}
.result-card:hover {
  border-color: var(--accent-line);
  transform: translateY(-3px);
}
.result-card h3 {
  font-size: 1.18rem;
  margin-bottom: 0.7rem;
  letter-spacing: -0.01em;
  color: var(--accent);
}
.result-card p {
  color: var(--text-soft);
  font-size: 0.95rem;
  line-height: 1.6;
}
@media (max-width: 760px) {
  .results-grid { grid-template-columns: 1fr; }
}

/* =========================================================
   BOOKING
   ========================================================= */
/* Free Consultation block (Calendly) */
.consult-block {
  background: var(--bg-card);
  border: 1px solid var(--accent-line);
  border-radius: 4px;
  padding: 1.6rem 1.6rem 1.2rem;
  margin-bottom: 2rem;
  position: relative;
}
.consult-block::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 32px; height: 32px;
  border-top: 1.5px solid var(--accent);
  border-left: 1.5px solid var(--accent);
  border-radius: 4px 0 0 0;
}
.consult-header {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  margin-bottom: 1.2rem;
}
.consult-icon {
  width: 44px; height: 44px;
  flex-shrink: 0;
  border-radius: 2px;
  background: var(--accent-dim);
  border: 1px solid var(--accent-line);
  display: grid;
  place-items: center;
  color: var(--accent);
}
.consult-header h3 {
  font-size: 1.3rem;
  margin-bottom: 0.4rem;
  color: var(--text);
}
.consult-header p {
  color: var(--text-soft);
  font-size: 0.95rem;
  margin: 0;
  line-height: 1.55;
}
.consult-block-cta {
  padding: 2.5rem 2.2rem;
}
.consult-cta-grid {
  display: grid;
  grid-template-columns: 1.6fr 1fr;
  gap: 2.5rem;
  align-items: center;
}
@media (max-width: 820px) {
  .consult-cta-grid { grid-template-columns: 1fr; gap: 1.8rem; }
}
.consult-cta-text .consult-icon {
  margin-bottom: 1.2rem;
}
.consult-cta-text h3 {
  font-size: 1.5rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  margin-bottom: 0.7rem;
  line-height: 1.25;
}
.consult-cta-text p {
  color: var(--text-soft);
  font-size: 1rem;
  line-height: 1.6;
  margin-bottom: 1.4rem;
}
.consult-features {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
.consult-features li {
  position: relative;
  padding-left: 1.6rem;
  color: var(--text-soft);
  font-size: 0.93rem;
  line-height: 1.5;
}
.consult-features li::before {
  content: '';
  position: absolute;
  left: 0; top: 0.5rem;
  width: 14px; height: 2px;
  background: var(--accent);
}
.consult-cta-action {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 0.8rem;
  padding-left: 2rem;
  border-left: 1px solid var(--border);
}
@media (max-width: 820px) {
  .consult-cta-action { padding-left: 0; border-left: none; padding-top: 1.4rem; border-top: 1px solid var(--border); }
}
.consult-cta-btn {
  width: 100%;
  justify-content: center;
  padding: 1.2rem 1.8rem;
  font-size: 1rem;
}
.consult-cta-btn .arrow {
  flex-shrink: 0;
}
.consult-cta-note {
  font-size: 0.82rem;
  color: var(--text-mute);
  text-align: center;
  margin: 0;
}
.consult-fallback {
  color: var(--text-mute);
  font-size: 0.9rem;
  text-align: center;
  padding: 2rem;
}
.consult-fallback a { color: var(--accent); }

/* OR divider between Calendly and inquiry form */
.bk-divider {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin: 2.5rem 0 2rem;
}
.bk-divider::before, .bk-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}
.bk-divider span {
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-mute);
  flex-shrink: 0;
}

.packages {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
  margin-bottom: 3rem;
}
.pkg-card {
  background: var(--bg-card);
  border: 1.5px solid var(--border);
  border-radius: 4px;
  padding: 1.6rem 1.3rem;
  cursor: pointer;
  position: relative;
  transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease;
}
.pkg-card:hover {
  border-color: var(--accent-line);
  transform: translateY(-3px);
}
.pkg-card.selected {
  border-color: var(--accent);
  background: linear-gradient(180deg, var(--accent-dim) 0%, var(--bg-card) 100%);
}
.pkg-card.popular::after {
  content: attr(data-popular);
  position: absolute;
  top: -10px; right: 12px;
  background: var(--accent);
  color: #ffffff;
  font-family: 'Inter', sans-serif;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  padding: 0.3rem 0.7rem;
  border-radius: 999px;
}
.pkg-name {
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 1.1rem;
  margin-bottom: 0.4rem;
}
.pkg-desc {
  font-size: 0.85rem;
  color: var(--text-soft);
  margin-bottom: 1rem;
  min-height: 38px;
}
.pkg-price {
  font-family: 'Inter', sans-serif;
  font-size: 1.15rem;
  color: var(--accent);
  font-weight: 600;
}

.booking-form {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 2.2rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}
.booking-form .full { grid-column: 1 / -1; }
.field-label {
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-mute);
  margin-bottom: 0.5rem;
  display: block;
}

.form-note {
  font-size: 0.85rem;
  color: var(--text-mute);
  margin-top: 1rem;
  line-height: 1.55;
  padding-left: 0.2rem;
}
.form-disclaimer {
  font-size: 0.78rem;
  color: var(--text-mute);
  text-align: center;
  margin-top: 1rem;
  line-height: 1.55;
}
.form-disclaimer a {
  color: var(--accent);
  text-decoration: underline;
  text-decoration-color: var(--accent-line);
  text-underline-offset: 3px;
}
.form-disclaimer a:hover { color: var(--accent-soft); }

.success-msg {
  display: none;
  background: linear-gradient(135deg, var(--accent-dim), transparent);
  border: 1px solid var(--accent);
  border-radius: 4px;
  padding: 1.5rem;
  margin-top: 1.5rem;
  align-items: center;
  gap: 1rem;
}
.success-msg.active { display: flex; }
.success-msg .check {
  width: 42px; height: 42px;
  border-radius: 50%;
  background: var(--accent);
  color: #ffffff;
  display: grid; place-items: center;
  flex-shrink: 0;
  font-weight: 700;
}
.success-msg h4 { color: var(--accent); margin-bottom: 0.3rem; font-size: 1.05rem; }
.success-msg p { color: var(--text-soft); font-size: 0.9rem; margin: 0; }

/* =========================================================
   CONTACT
   ========================================================= */
.contact-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 3rem 2.5rem;
  text-align: center;
  max-width: 720px;
  margin: 0 auto;
  position: relative;
  overflow: hidden;
}
.contact-card::before {
  content: '';
  position: absolute;
  top: -100px; left: 50%;
  width: 400px; height: 400px;
  background: radial-gradient(circle, var(--accent-dim) 0%, transparent 60%);
  transform: translateX(-50%);
  pointer-events: none;
}
.contact-card > * { position: relative; z-index: 1; }

.contact-mail {
  display: inline-block;
  font-family: 'Inter', sans-serif;
  font-size: clamp(1.4rem, 3.4vw, 2.2rem);
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--accent);
  margin: 1rem 0 1.5rem;
  border-bottom: 2px solid transparent;
  transition: border-color 0.2s ease;
}
.contact-mail:hover { border-bottom-color: var(--accent); }

.contact-meta {
  display: flex;
  justify-content: center;
  gap: 2rem;
  flex-wrap: wrap;
  font-family: 'Inter', sans-serif;
  font-size: 0.85rem;
  color: var(--text-soft);
  margin-top: 1.5rem;
}
.contact-meta span { display: flex; align-items: center; gap: 0.5rem; }
.contact-meta .ic { color: var(--accent); }

/* =========================================================
   FOOTER
   ========================================================= */
.footer {
  border-top: 1px solid var(--border);
  padding: 3.5rem 0 2.5rem;
  margin-top: 3rem;
}
.footer-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1.5rem;
}
.footer-lockup {
  height: 110px;
  width: auto;
  color: var(--accent);
  display: block;
  flex-shrink: 0;
}
@media (max-width: 760px) {
  .footer-lockup { height: 90px; }
  .footer-inner { justify-content: center; text-align: center; }
}
.footer .logo { font-size: 0.95rem; }
.footer-copy {
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  color: var(--text-mute);
  letter-spacing: 0.04em;
}
.footer-legal {
  display: flex;
  gap: 1.2rem;
  font-size: 0.85rem;
}
.footer-legal a {
  color: var(--text-soft);
  transition: color 0.2s ease;
}
.footer-legal a:hover { color: var(--accent); }

/* =========================================================
   RESPONSIVE
   ========================================================= */
@media (max-width: 960px) {
  .nav-links { display: none; }
  .nav-toggle { display: flex; }
  .nav-links.open {
    display: flex;
    position: absolute;
    top: 100%; left: 0; right: 0;
    flex-direction: column;
    background: var(--bg-2);
    padding: 1.1rem 1.1rem 1.4rem;
    border-bottom: 1px solid var(--border);
    box-shadow: 0 18px 36px rgba(30, 44, 71, 0.08);
    gap: 0.4rem;
    list-style: none;
    max-width: 100vw;
    box-sizing: border-box;
  }
  .nav-links.open li { width: 100%; }
  .nav-links.open a {
    display: block;
    padding: 0.85rem 0.4rem;
    border-bottom: 1px solid var(--border);
    font-size: 1rem;
    color: var(--text);
  }
  .nav-links.open a::after { display: none; }
  .nav-links.open .nav-mobile-controls {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1rem 0.4rem 0;
    margin-top: 0.4rem;
  }
  .nav-links.open .nav-mobile-controls .lang-select {
    flex: 1;
    max-width: none;
    font-size: 0.95rem;
    padding: 0.7rem 2.2rem 0.7rem 0.9rem;
  }
  .about-grid, .skills-wrapper { grid-template-columns: 1fr; gap: 2.5rem; }
  .services-grid, .proj-grid { grid-template-columns: repeat(2, 1fr); }
  .process-grid { grid-template-columns: repeat(2, 1fr); }
  .process-grid::before { display: none; }
  .packages { grid-template-columns: repeat(2, 1fr); }
  .booking-form { grid-template-columns: 1fr; }
  section { padding: 4.5rem 0; }
  .hero { padding: 9rem 0 5rem; }
}
@media (max-width: 760px) {
  /* Stats Band kompakter, Trust-Band nicht zu hoch */
  .stats-band { padding: 3rem 0; }
  .stats-band .container { padding: 0 1.5rem; }
  .trust-section { padding: 2.8rem 0; }
  /* Booking-CTA-Headline kleiner */
  .consult-cta-text h3 { font-size: 1.3rem; }
  /* Hero-Banner unterhalb der mobilen Nav */
  .hero-banner { margin-top: 60px; }
}

@media (max-width: 580px) {
  /* Container & Section spacing */
  .container { padding: 0 1.1rem; }
  section { padding: 3.5rem 0; }
  .hero { padding: 6.5rem 0 3.5rem; }

  /* Hero Typo */
  .hero h1 { font-size: 2.15rem; line-height: 1.06; letter-spacing: -0.025em; }
  .hero-tagline { font-size: 1rem; margin-bottom: 1.8rem; }
  .hero-meta { gap: 0.35rem 1.4rem; font-size: 0.82rem; margin-bottom: 1.8rem; }
  .hero-meta span::before { width: 10px; margin-right: 0.45rem; }
  .hero-badge { font-size: 0.72rem; margin-bottom: 1.2rem; }

  /* CTA-Buttons full-width auf Telefon */
  .cta-row { flex-direction: column; align-items: stretch; gap: 0.7rem; }
  .cta-row .btn { width: 100%; justify-content: center; padding: 1rem 1.4rem; }

  /* Section labels & titles */
  .section-title { font-size: 1.7rem; margin-bottom: 1rem; }
  .section-subtitle { font-size: 0.96rem; margin-bottom: 2.2rem; }
  .section-label { font-size: 0.72rem; margin-bottom: 1rem; }

  /* Stats Band — gestapelt mit Top-Border statt Left-Border */
  .stats-band { padding: 2.4rem 0; }
  .stats-band .container { padding: 0 1.1rem; }
  .stat-cell {
    padding: 1.4rem 0 0;
    margin-bottom: 0;
    border-left: none;
    border-top: 1px solid var(--border);
  }
  .stat-cell:first-child { border-top: none; padding-top: 0; }
  .stat-value { font-size: 2.4rem; }
  .stat-label { font-size: 0.92rem; }

  /* Trust Band */
  .trust-section { padding: 2.2rem 0; }
  .trust-grid { gap: 1.4rem; }
  .trust-text { font-size: 0.94rem; }

  /* Karten kompakter */
  .services-grid, .edu-grid, .packages, .stats, .proj-grid, .process-grid { grid-template-columns: 1fr; }
  .service-card { padding: 1.7rem 1.4rem 1.4rem; }
  .service-card h3 { font-size: 1.15rem; }
  .show-body { padding: 1.3rem 1.3rem 1.5rem; }
  .show-card h3 { font-size: 1.1rem; }
  .proc-step { padding: 2.2rem 1.3rem 1.5rem; }
  .proc-num { width: 50px; height: 50px; font-size: 1.2rem; margin: -3.4rem auto 1.1rem; }

  /* Projektkarten */
  .proj-meta {
    flex-direction: column;
    gap: 0.15rem;
    line-height: 1.4;
  }
  .proj-meta span:not(:last-child)::after { display: none; }
  .proj-card { padding: 1.6rem 1.4rem; }
  .nda-banner { font-size: 0.72rem; padding: 0.6rem 0.85rem; }

  /* Booking CTA */
  .consult-block-cta { padding: 1.7rem 1.3rem; }
  .consult-cta-grid { gap: 1.5rem; }
  .consult-cta-text h3 { font-size: 1.2rem; }
  .consult-cta-text p { font-size: 0.94rem; }
  .consult-cta-text .consult-icon { margin-bottom: 0.8rem; }
  .consult-cta-btn { padding: 1rem 1.4rem; font-size: 0.95rem; }
  .consult-features li { font-size: 0.88rem; }
  .booking-form { padding: 1.5rem; }

  /* About-Portrait passt sich an Phone-Höhe an */
  .about-portrait-frame { aspect-ratio: 4 / 5; max-width: none; }

  /* Hero-Banner: volles Bild auf Mobile (nicht beschnitten) */
  .hero-banner { margin-top: 56px; }

  /* Footer kompakter */
  .footer { padding: 2.5rem 0 1.8rem; }
  .footer-lockup { height: 70px; }

  /* Top-Navigation kompakt halten — Padding fluchtet mit .container */
  .nav-inner { padding: 0.7rem 1.1rem; gap: 0.5rem; }
  .logo .logo-text { display: none; }
  .nav-actions { gap: 0.4rem; }
  /* Sprach-Auswahl wandert in das Burger-Menü, nicht mehr in der Top-Bar */
  .nav-actions .lang-select { display: none; }
  .icon-btn, .nav-toggle { width: 36px; height: 36px; }
}

/* Sehr kleine Phones (iPhone SE 1st gen, kleine Android-Geräte) */
@media (max-width: 380px) {
  .container { padding: 0 0.9rem; }
  .nav-inner { padding: 0.65rem 0.9rem; }
  .hero h1 { font-size: 1.95rem; letter-spacing: -0.02em; }
  .section-title { font-size: 1.55rem; }
  .stat-value { font-size: 2.1rem; }
  .consult-cta-text h3 { font-size: 1.1rem; }
  .service-card h3, .show-card h3, .proc-step h3 { font-size: 1.05rem; }
}

/* =========================================================
   PROJECT PROFILES
   ========================================================= */
.proj-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.4rem;
}
.proj-card {
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: 0;
  padding: 2rem 1.8rem;
  display: flex;
  flex-direction: column;
  position: relative;
  transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  overflow: hidden;
}
.proj-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 0; height: 3px;
  background: var(--accent);
  transition: width 0.35s ease;
}
.proj-card:hover {
  border-color: var(--accent-line);
  transform: translateY(-6px);
  box-shadow: 0 18px 40px rgba(30, 44, 71, 0.10);
}
.proj-card:hover::before { width: 100%; }
.proj-meta {
  font-family: 'Inter', sans-serif;
  font-size: 0.76rem;
  font-weight: 600;
  color: var(--accent);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 1rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem 0.8rem;
}
.proj-meta span:not(:last-child)::after {
  content: '·';
  margin-left: 0.8rem;
  color: var(--text-mute);
}
.proj-card h3 {
  font-size: 1.2rem;
  font-weight: 700;
  margin-bottom: 0.9rem;
  letter-spacing: -0.02em;
  line-height: 1.3;
}
.proj-card p {
  color: var(--text-soft);
  font-size: 0.92rem;
  margin-bottom: 1.1rem;
  flex-grow: 1;
  line-height: 1.55;
}
.proj-csr {
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin-bottom: 1rem;
}
.proj-csr p {
  font-size: 0.86rem;
  margin-bottom: 0;
  flex-grow: 0;
  line-height: 1.5;
}
.proj-csr strong {
  font-family: 'Inter', sans-serif;
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 500;
}

.nda-banner {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-family: 'Inter', sans-serif;
  font-size: 0.75rem;
  color: var(--text-mute);
  background: var(--bg-3);
  border: 1px dashed var(--border-strong);
  border-radius: 2px;
  padding: 0.5rem 0.9rem;
  margin-top: 1.5rem;
  letter-spacing: 0.04em;
}
.nda-banner svg { color: var(--accent); flex-shrink: 0; }

/* =========================================================
   PROCESS / HOW WE WORK
   ========================================================= */
.process-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.3rem;
  position: relative;
}
.process-grid::before {
  content: '';
  position: absolute;
  top: 32px; left: 5%; right: 5%;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--accent-line), var(--accent-line), transparent);
  z-index: 0;
}
.proc-step {
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: 0;
  padding: 2.4rem 1.6rem 1.8rem;
  position: relative;
  z-index: 1;
  transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
}
.proc-step:hover {
  border-color: var(--accent-line);
  transform: translateY(-6px);
  box-shadow: 0 18px 40px rgba(30, 44, 71, 0.10);
}
.proc-num {
  width: 56px; height: 56px;
  border-radius: 0;
  background: var(--accent);
  border: none;
  color: #ffffff;
  display: grid; place-items: center;
  font-family: 'Inter', sans-serif;
  font-weight: 800;
  font-size: 1.35rem;
  margin: -3.6rem auto 1.4rem;
  position: relative;
  box-shadow: 0 0 0 8px var(--bg);
  letter-spacing: -0.02em;
}
.proc-step h3 {
  text-align: center;
  font-size: 1.15rem;
  font-weight: 700;
  margin-bottom: 0.7rem;
  letter-spacing: -0.02em;
}
.proc-step p {
  font-size: 0.92rem;
  color: var(--text-soft);
  text-align: center;
  line-height: 1.6;
}

/* =========================================================
   FAQ
   ========================================================= */
.faq-list {
  max-width: 880px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}
.faq-item {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 4px;
  overflow: hidden;
  transition: border-color 0.2s ease;
}
.faq-item.open { border-color: var(--accent-line); }
.faq-q {
  width: 100%;
  text-align: left;
  padding: 1.2rem 1.4rem;
  font-size: 1rem;
  font-weight: 500;
  color: var(--text);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  cursor: pointer;
  font-family: inherit;
  line-height: 1.4;
}
.faq-q:hover { color: var(--accent); }
.faq-q .plus {
  flex-shrink: 0;
  width: 22px; height: 22px;
  border: 1.5px solid var(--accent);
  border-radius: 50%;
  position: relative;
  transition: transform 0.25s ease, background 0.25s ease;
}
.faq-q .plus::before, .faq-q .plus::after {
  content: '';
  position: absolute;
  background: var(--accent);
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
}
.faq-q .plus::before { width: 10px; height: 1.5px; }
.faq-q .plus::after  { width: 1.5px; height: 10px; transition: transform 0.25s ease; }
.faq-item.open .faq-q .plus { background: var(--accent); }
.faq-item.open .faq-q .plus::before, .faq-item.open .faq-q .plus::after { background: var(--bg); }
.faq-item.open .faq-q .plus::after { transform: translate(-50%, -50%) scaleY(0); }
.faq-a {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}
.faq-a-inner {
  padding: 0 1.4rem 1.4rem;
  color: var(--text-soft);
  font-size: 0.93rem;
  line-height: 1.6;
}

/* =========================================================
   HERO CIRCUIT ANIMATION
   ========================================================= */
@keyframes node-pulse {
  0%, 100% { opacity: 0.85; r: 2.5; }
  50%      { opacity: 0.3;  r: 3.5; }
}
.hero-bg svg circle { animation: node-pulse 4s ease-in-out infinite; }
.hero-bg svg circle:nth-of-type(2n) { animation-delay: 0.7s; }
.hero-bg svg circle:nth-of-type(3n) { animation-delay: 1.4s; }
.hero-bg svg circle:nth-of-type(5n) { animation-delay: 2.1s; }

@keyframes flow {
  to { stroke-dashoffset: -300; }
}
.flow-line {
  stroke-dasharray: 6 14;
  animation: flow 8s linear infinite;
}


/* =========================================================
   PRIVACY MODAL (Centered Consent Dialog)
   ========================================================= */
.privacy-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100vw;
  height: 100vh;
  height: 100dvh;
  z-index: 1000;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 1rem;
  box-sizing: border-box;
}
.privacy-modal.show { display: flex; }
.privacy-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.78);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}
[data-theme="light"] .privacy-backdrop {
  background: rgba(246, 247, 249, 0.72);
}
.privacy-dialog {
  position: relative;
  background: var(--bg-2);
  border: 1px solid var(--accent-line);
  border-radius: 4px;
  max-width: 540px;
  width: 100%;
  padding: 1.8rem 1.6rem 1.4rem;
  max-height: 88vh;
  overflow-y: auto;
  box-shadow: 0 24px 70px rgba(0, 0, 0, 0.6);
}
.privacy-dialog h2 {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 1.35rem;
  color: var(--text);
  margin: 0 0 1.1rem;
  letter-spacing: -0.01em;
  text-align: center;
}
.privacy-content p {
  font-size: 0.9rem;
  color: var(--text-soft);
  line-height: 1.6;
  margin: 0 0 0.7rem;
}
.privacy-content p:last-child { margin-bottom: 0; }
.privacy-content a { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
.privacy-details {
  margin: 1rem 0 0;
  padding: 1rem 1.1rem;
  background: var(--bg-3);
  border: 1px solid var(--border);
  border-radius: 2px;
}
.privacy-details h3 {
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
  margin: 0 0 0.7rem;
  font-weight: 500;
}
.privacy-details ul { margin: 0; padding-left: 1.1rem; list-style: none; }
.privacy-details li {
  font-size: 0.83rem;
  color: var(--text-soft);
  line-height: 1.55;
  margin-bottom: 0.6rem;
  position: relative;
  padding-left: 0.4rem;
}
.privacy-details li:last-child { margin-bottom: 0; }
.privacy-details li::before {
  content: '▸';
  position: absolute;
  left: -0.9rem;
  color: var(--accent);
}
.privacy-details strong { color: var(--text); display: block; margin-bottom: 0.15rem; }
.privacy-actions {
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
  margin-top: 1.3rem;
}
.privacy-btn {
  padding: 0.85rem 1.2rem;
  border: none;
  border-radius: 2px;
  font-family: inherit;
  font-size: 0.92rem;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
  text-align: center;
}
.privacy-btn.primary {
  background: var(--accent);
  color: #ffffff;
}
.privacy-btn.primary:hover {
  background: var(--accent-soft);
  transform: translateY(-1px);
}
.privacy-btn.secondary {
  background: transparent;
  color: var(--text);
  border: 1px solid var(--border-strong);
}
.privacy-btn.secondary:hover {
  border-color: var(--accent);
  color: var(--accent);
}
.privacy-btn.link {
  background: transparent;
  color: var(--text-soft);
  font-size: 0.85rem;
  font-weight: 500;
  text-decoration: underline;
  text-underline-offset: 3px;
  padding: 0.5rem 0.8rem;
}
.privacy-btn.link:hover { color: var(--accent); }
.privacy-footer {
  display: flex;
  justify-content: center;
  gap: 1.4rem;
  margin-top: 1.1rem;
  padding-top: 1rem;
  border-top: 1px solid var(--border);
  font-size: 0.8rem;
}
.privacy-footer a {
  color: var(--text-mute);
  text-decoration: underline;
  text-underline-offset: 2px;
}
.privacy-footer a:hover { color: var(--accent); }

@media (max-width: 580px) {
  .privacy-dialog { padding: 1.4rem 1.2rem 1.1rem; }
  .privacy-dialog h2 { font-size: 1.2rem; }
}


/* =========================================================
