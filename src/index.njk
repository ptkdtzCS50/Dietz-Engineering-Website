    pollOperatorReplies();
    guidedAssistantState.replyPollTimer = setInterval(pollOperatorReplies, 1200);
  }

  async function pollOperatorReplies() {
    const endpoint = clean(assistantConfig.endpoint, 600);
    const sessionId = guidedAssistantState.sessionId;
    if (!endpoint || !sessionId) return;
    const base = endpoint.replace(/\/?$/, '');
    try {
      const response = await fetch(`${base}/replies?session_id=${encodeURIComponent(sessionId)}&after=${guidedAssistantState.replyCursor}`);
      const data = await response.json().catch(() => ({}));
      if (!response.ok || !data.ok) return;
      (data.replies || []).forEach(reply => {
        if (reply?.action === 'start_chat' || reply?.action === 'operator_reply') {
          guidedAssistantState.operatorActive = true;
          guidedAssistantState.ariaActive = false;
          guidedAssistantState.operatorWindowActive = false;
          if (guidedAssistantState.operatorTimer) clearTimeout(guidedAssistantState.operatorTimer);
          stopOperatorWindowCountdown();
          if (!guidedAssistantState.operatorActiveNoticeShown) {
            appendChatMessage('aria', assistantDict()['assistant.operatorActiveNotice'] || 'Patrick übernimmt jetzt den Chat. Aria hält sich zurück.');
            guidedAssistantState.operatorActiveNoticeShown = true;
          }
        }
        if (reply?.message) appendChatMessage('aria', reply.message);
        if (reply?.action === 'end_chat') {
          guidedAssistantState.operatorActive = false;
          if (guidedAssistantState.replyPollTimer) clearInterval(guidedAssistantState.replyPollTimer);
          appendChatMessage('aria', assistantDict()['assistant.operatorClosedNotice'] || 'Patrick hat den Livechat beendet. Aria kann wieder bei der Einordnung helfen.');
        }
      });
      guidedAssistantState.replyCursor = Number(data.next || guidedAssistantState.replyCursor);
      if ((data.replies || []).length && guidedAssistantState.operatorTimer) clearTimeout(guidedAssistantState.operatorTimer);
      if ((data.replies || []).length) { guidedAssistantState.operatorWindowActive = false; stopOperatorWindowCountdown(); }
    } catch (error) { /* local dev polling should stay quiet */ }
  }

  async function notifyPatrickForLiveChat(summary) {
    const fallback = buildAssistantFallbackReply(summary, 'patrick_notification_pending');
    lastAssistantResult = fallback;
    const endpoint = clean(assistantConfig.endpoint, 600);
    if (!endpoint) return { ok: false, skipped: true, reason: 'handoff_endpoint_missing' };
    try {
      const handoff = await sendAssistantLead(summary, fallback);
      if (handoff?.session_id) startOperatorReplyPolling(handoff.session_id);
      return handoff;
    } catch (error) {
      return { ok: false, skipped: true, reason: 'handoff_error' };
    }
  }

  function hasAssistantHandoffConsent() {
    return document.getElementById('assistantConsent')?.checked === true;
  }

  function requireAssistantHandoffConsent(dict) {
    if (hasAssistantHandoffConsent()) return true;
    appendChatMessage('aria', dict['assistant.consentRequired']);
    setOutput(dict['assistant.consentRequired']);
    return false;
  }


  async function forwardCustomerMessageToOperator(message, summary) {
    const endpoint = clean(assistantConfig.endpoint, 600);
    const sessionId = guidedAssistantState.sessionId;
    if (!endpoint || !sessionId) return { ok: false, skipped: true, reason: 'operator_endpoint_missing' };
    const base = endpoint.replace(/\/?$/, '');
    try {
      const response = await fetch(`${base.replace(/\/assistant$/, '')}/operator/customer-message`, {
        method: 'POST', headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ session_id: sessionId, message, language: langSelect?.value || 'de', context: summary })
      });
      return await response.json().catch(() => ({ ok: response.ok }));
    } catch (error) {
      return { ok: false, skipped: true, reason: 'operator_forward_failed' };
    }
  }

  async function requestAiFallbackAfterOperatorWindow() {
    if (guidedAssistantState.aiFallbackStarted || guidedAssistantState.ariaActive) return;
    guidedAssistantState.aiFallbackStarted = true;
    guidedAssistantState.operatorWindowActive = false;
    stopOperatorWindowCountdown();
    const dict = assistantDict();
    const summary = buildAssistantSummary();
    appendChatMessage('aria', dict['assistant.aiFallback']);
    await answerWithAria(summary, 'operator_window_elapsed');
  }

  launcher.addEventListener('click', () => panel.classList.contains('open') ? closeAssistant() : openAssistant());
  closeBtn.addEventListener('click', closeAssistant);
  document.addEventListener('keydown', (event) => { if (event.key === 'Escape' && panel.classList.contains('open')) closeAssistant(); });

  document.querySelectorAll('#assistantProjectTypes .assistant-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('#assistantProjectTypes .assistant-chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      selectedTypeKey = chip.dataset.typeKey || selectedTypeKey;
    });
  });

  function buildDietzAssistantPersona() {
    return {
      role: DIETZ_ASSISTANT_KNOWLEDGE.identity,
      purpose: 'Vertrauen schaffen, erste technische Fragen ehrlich beantworten und verbindliche Themen an Patrick übergeben.',
      knowledge: DIETZ_ASSISTANT_KNOWLEDGE,
      style: ['ruhig', 'ehrlich', 'technisch konkret', 'nicht übertrieben', 'nicht salesy'],
      forbidden_claims: DIETZ_ASSISTANT_KNOWLEDGE.boundaries
    };
  }

  function buildAssistantSummary() {
    const dict = assistantDict();
    const activeChip = document.querySelector('#assistantProjectTypes .assistant-chip.active');
    const activeTypeKey = activeChip?.dataset.typeKey || selectedTypeKey;
    const selectedType = dict[activeTypeKey] || activeChip?.textContent.trim() || dict['assistant.typeEplan'];
    const machineFallback = dict['assistant.machineFallback'];
    const scopeFallback = dict['assistant.scopeFallback'];
    const machine = clean(document.getElementById('assistantMachine')?.value, 140) || machineFallback;
    const scope = clean(document.getElementById('assistantScope')?.value, 900) || scopeFallback;
    const question = clean(document.getElementById('assistantQuestion')?.value, 900);
    const timeline = document.getElementById('assistantTimeline')?.selectedOptions[0]?.textContent.trim() || dict['assistant.timelineOpen'];
    const missing = [];
    if (machine === machineFallback) missing.push(dict['assistant.missingMachine']);
    if (scope === scopeFallback) missing.push(dict['assistant.missingScope']);
    if (activeTypeKey === 'assistant.typeSafety') missing.push(dict['assistant.missingSafety']);
    if (activeTypeKey === 'assistant.typeEplan') missing.push(dict['assistant.missingEplan']);
    if (activeTypeKey === 'assistant.typeSps') missing.push(dict['assistant.missingSps']);
    const contact_name = clean(document.getElementById('assistantContactName')?.value, 140);
    const contact_contact = clean(document.getElementById('assistantContactContact')?.value, 180);
    return { project_type: selectedType, project_type_key: activeTypeKey, machine, scope, question, timeline, contact_name, contact_contact, missing_information: missing, privacy_note: dict['assistant.privacyNote'] };
  }

  function shouldEscalateToPatrick(summary, replyText = '') {
    const text = `${summary.question} ${summary.scope} ${replyText}`.toLowerCase();
    const reviewMarkers = ['preis', 'kosten', 'angebot', 'termin', 'lieferzeit', 'ce', 'safety', 'norm', 'garantie', 'vertrag', 'confidential', 'vertraulich'];
    return summary.missing_information.length > 0 || reviewMarkers.some(marker => text.includes(marker)) || assistantConfig.handoffMode === 'telegram_review';
  }

  function buildAssistantFallbackReply(summary, reason = 'token_or_endpoint_fallback') {
    const dict = assistantDict();
    if (!isAssistantQuestionInScope(summary)) {
      return { mode: 'fallback', fallback_reason: 'out_of_scope', intent: 'out_of_scope_boundary', reply: dict['assistant.outOfScope'], requires_human: false, escalation_reason: 'not_project_related' };
    }
    const text = `${summary.question} ${summary.scope} ${summary.project_type}`.toLowerCase();
    const asksEplanMacro = ['eplan', 'makro', 'macro', 'data portal', 'pro panel'].some(term => text.includes(term));
    const answer = asksEplanMacro ? dict['assistant.trustEplanMacro'] : dict['assistant.defaultTrustReply'];
    return {
      mode: 'fallback', fallback_reason: reason, intent: asksEplanMacro ? 'eplan_macro_trust_question' : 'project_triage',
      reply: `${dict['assistant.localFallbackNotice']}\n\n${answer}\n\n${dict['assistant.boundaryNoGuarantee']}`,
      requires_human: shouldEscalateToPatrick(summary, answer), escalation_reason: 'review_required_personal_patrick'
    };
  }

  async function callAssistantEndpoint(summary) {
    const endpoint = clean(assistantConfig.endpoint, 600);
    if (!assistantConfig.liveAiEnabled || !endpoint) return buildAssistantFallbackReply(summary, 'local_aria_answer');
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), Number(assistantConfig.timeoutMs) || 9000);
    try {
      const response = await fetch(endpoint, {
        method: 'POST', headers: { 'content-type': 'application/json' }, signal: controller.signal,
        body: JSON.stringify({
          language: langSelect?.value || 'de', persona: buildDietzAssistantPersona(), context: summary,
          messages: [{ role: 'user', content: summary.question || summary.scope || summary.project_type }]
        })
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || !data.reply) return buildAssistantFallbackReply(summary, data.fallback_reason || 'token_or_endpoint_fallback');
      return Object.assign({ mode: 'live_ai', requires_human: shouldEscalateToPatrick(summary, data.reply) }, data);
    } catch (error) {
      return buildAssistantFallbackReply(summary, 'token_or_endpoint_fallback');
    } finally { clearTimeout(timeout); }
  }

  async function sendAssistantLead(summary, result) {
    if (!hasAssistantHandoffConsent()) return { ok: false, skipped: true, reason: 'consent_required' };
    const endpoint = clean(assistantConfig.endpoint, 600);
    const leadEndpoint = endpoint ? endpoint.replace(/\/?$/, '/lead') : '';
    if (!leadEndpoint) return { ok: false, skipped: true, reason: 'handoff_endpoint_missing' };
    const response = await fetch(leadEndpoint, {
      method: 'POST', headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        session_id: guidedAssistantState.sessionId || undefined,
        language: langSelect?.value || 'de', confirmed: true, fallback_reason: result?.fallback_reason || 'manual_handoff',
        context: summary, question: summary.question || summary.scope,
        customer: { name: clean(document.getElementById('assistantContactName')?.value, 140), contact: clean(document.getElementById('assistantContactContact')?.value, 180) }
      })
    });
    const data = await response.json().catch(() => ({ ok: response.ok }));
    if (data?.session_id) startOperatorReplyPolling(data.session_id);
    return data;
  }

  function formatAssistantSummary(summary) {
    const dict = assistantDict();
    return [
      dict['assistant.summaryTitle'],
      `- ${dict['assistant.summaryType']}: ${summary.project_type}`,
      `- ${dict['assistant.summaryMachine']}: ${summary.machine}`,
      `- ${dict['assistant.summaryScope']}: ${summary.scope}`,
      summary.question ? `- ${dict['assistant.question']}: ${summary.question}` : '',
      `- ${dict['assistant.summaryTimeline']}: ${summary.timeline}`,
      summary.missing_information.length ? `- ${dict['assistant.summaryMissing']}: ${summary.missing_information.join('; ')}` : `- ${dict['assistant.summaryMissing']}: ${dict['assistant.summaryNone']}`,
      `- ${dict['assistant.summaryNote']}: ${summary.privacy_note}`
    ].filter(Boolean).join('\n');
  }

  function fillCustomerFieldsFromAssistant(summary) {
    const fullName = clean(summary.contact_name, 140);
    const contact = clean(summary.contact_contact, 180);
    const parts = fullName.split(' ').filter(Boolean);
    const firstField = document.querySelector('#bookingForm input[name="firstname"]');
    const lastField = document.querySelector('#bookingForm input[name="lastname"]');
    const emailField = document.querySelector('#bookingForm input[name="email"]');
    if (firstField && parts[0] && !firstField.value) firstField.value = parts.shift();
    if (lastField && parts.length && !lastField.value) lastField.value = parts.join(' ');
    if (emailField && /@/.test(contact) && !emailField.value) emailField.value = contact;
    [firstField, lastField, emailField].filter(Boolean).forEach(field => {
      field.dispatchEvent(new Event('input', { bubbles: true }));
      field.dispatchEvent(new Event('change', { bubbles: true }));
    });
  }

  function fillBookingForm(summary) {
    const formatted = formatAssistantSummary(summary);
    fillCustomerFieldsFromAssistant(summary);
    const projectField = document.querySelector('#bookingForm textarea[name="project"], textarea[name="project"]');
    if (projectField) {
      projectField.value = formatted;
      projectField.dispatchEvent(new Event('input', { bubbles: true }));
      projectField.dispatchEvent(new Event('change', { bubbles: true }));
    }
    const pkgField = document.getElementById('selectedPackage');
    if (pkgField) {
      pkgField.value = summary.project_type;
      pkgField.dispatchEvent(new Event('input', { bubbles: true }));
      pkgField.dispatchEvent(new Event('change', { bubbles: true }));
    }
    return Boolean(projectField);
  }

  askBtn?.addEventListener('click', async () => {
    const dict = assistantDict();
    const summary = buildAssistantSummary();
    guidedAssistantState.turns += 1;
    if (!summary.question && summary.scope === dict['assistant.scopeFallback']) { setOutput(dict['assistant.emptyQuestionPrompt'], 'question_missing_local_prompt'); return; }
    if (!isAssistantQuestionInScope(summary)) {
      lastAssistantResult = buildAssistantFallbackReply(summary, 'out_of_scope');
      setOutput(lastAssistantResult.reply);
      return;
    }
    setOutput('…');
    lastAssistantResult = await callAssistantEndpoint(summary);
    setOutput(lastAssistantResult.reply);
    fillBookingForm(summary);
  });

  prepareBtn.addEventListener('click', () => {
    const summary = buildAssistantSummary();
    const dict = assistantDict();
    const hasField = fillBookingForm(summary);
    const fallback = buildAssistantFallbackReply(summary, assistantConfig.liveAiEnabled ? 'prepared_triage' : 'local_aria_answer');
    lastAssistantResult = fallback;
    setOutput(hasField ? dict['assistant.outputDone'] : dict['assistant.outputNoField'], fallback.reply);
    document.getElementById('booking')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  async function requestLiveTakeover() {
    const dict = assistantDict();
    if (!requireAssistantHandoffConsent(dict)) return;
    guidedAssistantState.takeoverRequested = true;
    const summary = buildAssistantSummary();
    fillBookingForm(summary);
    guidedAssistantState.operatorWindowActive = true;
    appendChatMessage('aria', dict['assistant.waitingPatrick']);
    await notifyPatrickForLiveChat(summary);
    startOperatorWindowCountdown(60);
    if (guidedAssistantState.operatorTimer) clearTimeout(guidedAssistantState.operatorTimer);
    guidedAssistantState.operatorTimer = setTimeout(requestAiFallbackAfterOperatorWindow, 60000);
  }

  async function handleAssistantChatSend() {
    const dict = assistantDict();
    const message = clean(chatInput?.value, 900);
    if (!message) return;
    chatInput.value = '';
    if (guidedAssistantState.operatorActive) {
      const intentField = updateGuidedSummaryFromMessageIntent(message);
      if (!intentField) updateGuidedSummaryFromExpectedField(message);
      appendChatMessage('user', message);
      const summary = buildAssistantSummary();
      fillBookingForm(summary);
      await forwardCustomerMessageToOperator(message, summary);
      return;
    }
    if (isLowInformationChatMessage(message)) {
      appendChatMessage('user', message);
      appendChatMessage('aria', assistantDict()['assistant.stillHerePrompt'] || 'Ja, ich bin da. Bitte schreiben Sie kurz die konkrete technische Frage oder den nächsten Punkt.');
      return;
    }
    let capturedField = updateGuidedSummaryFromMessageIntent(message);
    if (!capturedField) capturedField = updateGuidedSummaryFromExpectedField(message);
    if (!capturedField) syncFreeTextToSummary(message);
    appendChatMessage('user', message);
    const summary = buildAssistantSummary();
    guidedAssistantState.turns += 1;
    if (!isAssistantQuestionInScope(summary)) {
      const result = buildAssistantFallbackReply(summary, 'out_of_scope');
      lastAssistantResult = result;
      appendChatMessage('aria', result.reply);
      return;
    }
    fillBookingForm(summary);

    if (guidedAssistantState.ariaActive && !shouldRequestPatrickFromMessage(message)) {
      await answerWithAria(summary, 'local_aria_followup', capturedField);
      return;
    }

    if (guidedAssistantState.operatorWindowActive && !shouldRequestPatrickFromMessage(message)) {
      appendChatMessage('aria', dict['assistant.operatorCollecting'] || 'Danke, ich nehme die Ergänzung mit. Aria übernimmt nach Ablauf des Timers automatisch.');
      return;
    }

    if (shouldRequestPatrickFromMessage(message) || !guidedAssistantState.patrickNotified) {
      if (!requireAssistantHandoffConsent(dict)) {
        await answerWithAria(summary, 'local_aria_answer', capturedField);
        return;
      }
      guidedAssistantState.patrickNotified = true;
      guidedAssistantState.ariaActive = false;
      guidedAssistantState.aiFallbackStarted = false;
      guidedAssistantState.operatorWindowActive = true;
      appendChatMessage('aria', dict['assistant.waitingPatrick']);
      await notifyPatrickForLiveChat(summary);
      startOperatorWindowCountdown(60);
      if (guidedAssistantState.operatorTimer) clearTimeout(guidedAssistantState.operatorTimer);
      guidedAssistantState.operatorTimer = setTimeout(requestAiFallbackAfterOperatorWindow, 60000);
      return;
    }

    await answerWithAria(summary, 'local_aria_followup', capturedField);
  }

  chatSendBtn?.addEventListener('click', handleAssistantChatSend);
  chatInput?.addEventListener('keydown', (event) => {
    if (event.key === 'Enter' && !event.shiftKey) {
      event.preventDefault();
      handleAssistantChatSend();
    }
  });

  confirmBtn?.addEventListener('click', async () => {
    const dict = assistantDict();
    const consent = document.getElementById('assistantConsent');
    if (!consent?.checked) { setOutput(dict['assistant.consentRequired']); return; }
    const summary = buildAssistantSummary();
    const result = lastAssistantResult || buildAssistantFallbackReply(summary, 'manual_handoff');
    fillBookingForm(summary);
    try {
      const handoff = await sendAssistantLead(summary, result);
      if (handoff?.session_id) startOperatorReplyPolling(handoff.session_id);
      setOutput(handoff.ok || handoff.delivered ? dict['assistant.handoffDone'] : dict['assistant.handoffFailed']);
    } catch (error) { setOutput(dict['assistant.handoffFailed']); }
  });

  takeoverBtn?.addEventListener('click', requestLiveTakeover);
})();
/* =========================================================
   PRIVACY MODAL (centered consent dialog)
   ========================================================= */
(function() {
  const modal = document.getElementById('privacyModal');
  if (!modal) return;
  const acceptBtn   = document.getElementById('privacyAcceptAll');
  const continueBtn = document.getElementById('privacyContinue');
  const customizeBtn= document.getElementById('privacyCustomize');
  const detailsEl   = document.getElementById('privacyDetails');

  let consent = null;
  try { consent = localStorage.getItem('de_privacy_v2'); } catch(e){}

  if (!consent) {
    setTimeout(() => modal.classList.add('show'), 700);
  }

  function close(choice) {
    try { localStorage.setItem('de_privacy_v2', choice); } catch(e){}
    modal.classList.remove('show');
  }

  acceptBtn.addEventListener('click', () => close('accept'));
  continueBtn.addEventListener('click', () => close('reject'));
  customizeBtn.addEventListener('click', () => {
    detailsEl.hidden = !detailsEl.hidden;
    customizeBtn.scrollIntoView({behavior:'smooth', block:'nearest'});
  });
})();
</script>
