      questionField.dispatchEvent(new Event('input', { bubbles: true }));
      questionField.dispatchEvent(new Event('change', { bubbles: true }));
    }
    if (scopeField && !clean(scopeField.value)) {
      scopeField.value = message;
      scopeField.dispatchEvent(new Event('input', { bubbles: true }));
      scopeField.dispatchEvent(new Event('change', { bubbles: true }));
