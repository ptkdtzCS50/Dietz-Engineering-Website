<script>
/* Activate JS-only styles (fade-ins) — without this class, content
   remains visible even when this script is blocked or errors out. */
document.documentElement.classList.add('js-ready');
/* I18N STRINGS — geladen aus src/_data/i18n.json (per Eleventy) */
const i18n = {{ i18n | dump | safe }};

/* =========================================================
   STATE  (declared up front — must exist before applyLang runs,
   otherwise the let-bindings below would throw a ReferenceError
   from the temporal dead zone and crash the whole script)
   ========================================================= */
const langSelect = document.getElementById('langSelect');

const pkgNameMap = {
  quick:   { de:'Quick Check',          en:'Quick Check',          es:'Quick Check',           zh:'Quick Check' },
  starter: { de:'EPLAN Starter',        en:'EPLAN Starter',        es:'EPLAN Starter',         zh:'EPLAN Starter' },
  sprint:  { de:'Engineering Sprint',   en:'Engineering Sprint',   es:'Engineering Sprint',    zh:'Engineering Sprint' },
  custom:  { de:'Custom Projekt',       en:'Custom Project',       es:'Proyecto a medida',     zh:'定制项目' }
};
let selectedPkg = 'quick';

function refreshSelectedPackage() {
  const lang = langSelect.value;
  const el = document.getElementById('selectedPackage');
  if (!el) return;
  el.value = (pkgNameMap[selectedPkg] && pkgNameMap[selectedPkg][lang]) || pkgNameMap[selectedPkg].de;
}

/* =========================================================
   LANGUAGE SWITCHING
   ========================================================= */
function applyLang(lang) {
  const dict = i18n[lang] || i18n.de;
  document.documentElement.lang = lang;

  // Klassische data-i18n-Keys (für statisch zugewiesene globale Strings: nav,
  // section-titles, FAQ etc., die aus dem zentralen i18n-Dict kommen).
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    if (dict[key] === undefined) return;
    if (el.hasAttribute('data-i18n-html')) {
      el.innerHTML = dict[key];
    } else {
      el.textContent = dict[key];
    }
  });

  // Form-Placeholder via data-i18n-placeholder
  document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
    const key = el.getAttribute('data-i18n-placeholder');
    if (dict[key] !== undefined) el.setAttribute('placeholder', dict[key]);
  });

  // Inline-Übersetzungen via data-translations (für Listendaten aus _data/*.json,
  // z.B. Projekt-Karten — JSON-Objekt {de, en, es, zh} direkt am Element).
  document.querySelectorAll('[data-translations]').forEach(el => {
    try {
      const translations = JSON.parse(el.getAttribute('data-translations'));
      if (translations[lang]) {
        el.textContent = translations[lang];
      } else if (translations.de) {
        el.textContent = translations.de;
      }
    } catch(e) {
      /* Malformed JSON — silently ignore so other elements continue updating. */
    }
  });

  refreshSelectedPackage();
  try { localStorage.setItem('de_lang', lang); } catch(e){}
}

let storedLang = 'de';
try { storedLang = localStorage.getItem('de_lang') || 'de'; } catch(e){}
langSelect.value = storedLang;
applyLang(storedLang);
langSelect.addEventListener('change', e => {
  applyLang(e.target.value);
  if (langSelectMobile) langSelectMobile.value = e.target.value;
});

/* Mobile-Sprachauswahl (in Burger-Menü): mit Desktop-Select synchronisieren */
const langSelectMobile = document.getElementById('langSelectMobile');
if (langSelectMobile) {
