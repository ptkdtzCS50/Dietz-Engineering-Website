    if (capturedField === 'machine') {
      lines.push((dict['assistant.ackMachine'] || 'Danke, ich habe {machine} als Maschine/Anlage notiert.').replace('{machine}', summary.machine));
      guidedAssistantState.awaitingField = 'eplan_specific';
      lines.push(dict['assistant.askSpecificEplan'] || 'Welche konkrete EPLAN-Frage soll geklärt werden?');
      return lines.join('\n\n');
    }

    if (capturedField === 'price') {
      guidedAssistantState.awaitingField = 'scope';
      return dict['assistant.priceBoundary'] || 'Einen belastbaren Preis kann ich ohne Prüfung nicht nennen. Für eine grobe Einordnung fehlen Umfang, Unterlagenstand, Anzahl Antriebe und gewünschte Lieferung.';
    }
    if (capturedField === 'drive_count') {
      guidedAssistantState.awaitingField = 'scope';
      return dict['assistant.ackDriveCount'] || 'Danke, die Anzahl der Antriebe ist notiert. Welche Nennleistungen und Umrichter/Starter sind betroffen?';
    }
    if (capturedField === 'timeline') {
      guidedAssistantState.awaitingField = 'contact';
      return `${dict['assistant.ackTimeline'] || 'Danke, den Termin habe ich notiert.'}\n\n${dict['assistant.nextContact']}`;
    }
    if (capturedField === 'contact_name') {
      guidedAssistantState.awaitingField = 'contact';
      return dict['assistant.askContactChannel'] || 'Danke. Bitte ergänzen Sie noch E-Mail oder Telefonnummer, falls Patrick außerhalb dieses Chats antworten soll.';
