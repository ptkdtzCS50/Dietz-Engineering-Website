/* =========================================================
   FORM SUBMIT (Web3Forms backend)
   ========================================================= */
const bookingForm = document.getElementById('bookingForm');
const successMsg  = document.getElementById('successMsg');
const submitBtn   = bookingForm.querySelector('button[type="submit"]');

bookingForm.addEventListener('submit', async (e) => {
  e.preventDefault();
  if (!bookingForm.checkValidity()) {
    bookingForm.reportValidity();
    return;
  }

  const accessKey = document.getElementById('w3f_access_key').value;
  // Wenn der Access-Key noch nicht gesetzt wurde, simulieren wir Erfolg (Demo-Modus)
  // — verhindert kaputte Form-Submissions vor dem ersten Web3Forms-Setup.
  if (!accessKey || accessKey === 'REPLACE_WITH_YOUR_WEB3FORMS_ACCESS_KEY') {
    console.warn('[bookingForm] Kein Web3Forms-Access-Key konfiguriert — Demo-Modus aktiv.');
    successMsg.classList.add('active');
    bookingForm.reset();
    refreshSelectedPackage();
    setTimeout(() => successMsg.scrollIntoView({behavior:'smooth', block:'center'}), 80);
    return;
  }

  const originalText = submitBtn.innerHTML;
  submitBtn.disabled = true;
  submitBtn.innerHTML = '<span>…</span>';

  try {
    const formData = new FormData(bookingForm);
    const response = await fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      body: formData
    });
    const result = await response.json();

    if (result.success) {
      successMsg.classList.add('active');
      bookingForm.reset();
      refreshSelectedPackage();
      setTimeout(() => successMsg.scrollIntoView({behavior:'smooth', block:'center'}), 80);
    } else {
      throw new Error(result.message || 'Submission failed');
    }
  } catch (err) {
    console.error('[bookingForm] Submit-Fehler:', err);
    const dict = i18n[langSelect.value] || i18n.de;
    alert(dict['bk.errorMsg'] || 'Es gab einen Fehler beim Senden. Bitte versuchen Sie es erneut oder schreiben Sie eine E-Mail an patrick@dietz-engineering.com.');
  } finally {
    submitBtn.disabled = false;
    submitBtn.innerHTML = originalText;
  }
});

/* =========================================================
   FAQ ACCORDION
   ========================================================= */
document.querySelectorAll('.faq-item').forEach(item => {
  const q = item.querySelector('.faq-q');
  const a = item.querySelector('.faq-a');
  q.addEventListener('click', () => {
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(el => {
      el.classList.remove('open');
      const inner = el.querySelector('.faq-a');
      if (inner) inner.style.maxHeight = '0px';
    });
    if (!isOpen) {
      item.classList.add('open');
      a.style.maxHeight = a.scrollHeight + 'px';
    }
  });
});

/* =========================================================
   FADE-IN ON SCROLL
   ========================================================= */
const io = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('in');
      // animate skill bars
      e.target.querySelectorAll('.bar-fill').forEach(b => {
        const val = b.getAttribute('data-fill');
        b.style.width = val + '%';
      });
      io.unobserve(e.target);
    }
  });
}, { threshold: 0.12 });

document.querySelectorAll('.fade').forEach(el => io.observe(el));

/* Year */
document.getElementById('year').textContent = new Date().getFullYear();

/* =========================================================
   PRIVACY MODAL (centered consent dialog)
   ========================================================= */
(function() {
  const modal = document.getElementById('privacyModal');
  if (!modal) return;
  const acceptBtn   = document.getElementById('privacyAcceptAll');
  const continueBtn = document.getElementById('privacyContinue');
  const customizeBtn= document.getElementById('privacyCustomize');
  const detailsEl   = document.getElementById('privacyDetails');

  let consent = null;
  try { consent = localStorage.getItem('de_privacy_v2'); } catch(e){}

  if (!consent) {
    setTimeout(() => modal.classList.add('show'), 700);
  }

  function close(choice) {
    try { localStorage.setItem('de_privacy_v2', choice); } catch(e){}
    modal.classList.remove('show');
  }

  acceptBtn.addEventListener('click', () => close('accept'));
  continueBtn.addEventListener('click', () => close('reject'));
  customizeBtn.addEventListener('click', () => {
    detailsEl.hidden = !detailsEl.hidden;
    customizeBtn.scrollIntoView({behavior:'smooth', block:'nearest'});
  });
})();
</script>
