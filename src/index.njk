  }



  function isPriceQuestion(message) {
    const text = clean(message, 220).toLowerCase();
    return ['preis', 'kosten', 'kostet', 'budget', 'angebot', 'stundensatz'].some(term => text.includes(term));
  }

  function updateGuidedSummaryFromMessageIntent(message) {
    const value = clean(message, 220);
    const text = value.toLowerCase();
    const scopeField = document.getElementById('assistantScope');
    const appendScope = (label, detail) => {
      if (!scopeField || !detail) return;
      const current = clean(scopeField.value, 900);
      const line = `${label}: ${detail}`;
      scopeField.value = current && !current.includes(line) ? `${current}
${line}` : (current || line);
      scopeField.dispatchEvent(new Event('input', { bubbles: true }));
      scopeField.dispatchEvent(new Event('change', { bubbles: true }));
    };
    if (isPriceQuestion(value)) return 'price';
    if (/\d+\s*(antriebe|motoren|achsen)/i.test(value)) { appendScope('Antriebe/Motoren', value); return 'drive_count'; }
    if (/(montag|dienstag|mittwoch|donnerstag|freitag|samstag|sonntag|\d{1,2}\.\d{1,2}\.\d{2,4}|morgen|heute|nächste|naechste)/i.test(value)) { appendScope('Termin/Rückmeldung', value); guidedAssistantState.awaitingField = 'contact'; return 'timeline'; }
    if (guidedAssistantState.awaitingField === 'contact') {
      if (/@|\+?\d[\d\s/()-]{5,}/.test(value)) {
        const contactField = document.getElementById('assistantContactContact');
        if (contactField) { contactField.value = value; contactField.dispatchEvent(new Event('input', { bubbles: true })); contactField.dispatchEvent(new Event('change', { bubbles: true })); }
