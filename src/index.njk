    if (capturedField === 'contact_channel_question') {
      guidedAssistantState.awaitingField = 'contact';
      return dict['assistant.chatContactClarify'] || 'Für den lokalen Test ja. Für eine echte Projektanfrage wäre zusätzlich E-Mail oder Telefon sinnvoll.';
    }
    if (capturedField === 'contact') {
      guidedAssistantState.awaitingField = '';
      return dict['assistant.contactComplete'] || 'Danke, Kontakt ist notiert. Ich kann Patrick die Einordnung damit sauber übergeben.';
    }
    if (capturedField === 'scope' || capturedField === 'eplan_specific') {
      guidedAssistantState.awaitingField = summary.timeline === dict['assistant.timelineOpen'] ? 'timeline' : 'contact';
      lines.push(dict['assistant.ackScope'] || 'Danke, das hilft für die Einordnung.');
      lines.push(dict['assistant.nextTimeline']);
      return lines.join('\n\n');
