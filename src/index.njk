      return `${dict['assistant.shortEplanIntro'] || dict['assistant.defaultTrustReply']}

${dict['assistant.askSpecificEplan'] || dict['assistant.nextScope']}`;
    }

    const nextQuestion = getAssistantNextQuestion(summary);
    if (nextQuestion) {
      if (nextQuestion === dict['assistant.nextMachine']) guidedAssistantState.awaitingField = 'machine';
      else if (nextQuestion === dict['assistant.nextScope']) guidedAssistantState.awaitingField = isEplan ? 'eplan_specific' : 'scope';
