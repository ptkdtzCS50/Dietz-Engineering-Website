  function buildConversationalAriaReply(summary, capturedField = '') {
    const dict = assistantDict();
    const text = `${summary.question} ${summary.scope} ${summary.project_type}`.toLowerCase();
    const isEplan = summary.project_type_key === 'assistant.typeEplan' || text.includes('eplan');
