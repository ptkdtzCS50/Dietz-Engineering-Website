<body>
<div id="login" class="login" data-customer-care-login>
  <div class="login-card">
    <section class="brand-pane">
      <div class="brand-logo"><div class="brand-mark">D</div><div><div class="brand-name">DIETZ</div><div class="brand-system">Customer Care</div></div></div>
      <h1 data-i18n="loginHeroTitle">Support, Service und Klärung in einer Arbeitsfläche.</h1>
      <p class="muted" data-i18n="loginHeroCopy">Ticketaufnahme, KI-Vorqualifizierung, Telegram-Eskalation und Rollenmodell für Kunden, Clarifier, Fieldservice und Admin.</p>
      <p class="notice" data-i18n="loginNotice">Demo-Portal: Login und Daten laufen lokal im Browser. Supabase Auth, RLS, Storage und Edge Functions sind als nächster Backend-Schritt vorbereitet.</p>
    </section>
    <form id="loginForm" class="login-form">
      <div class="kicker">DIETZ Engineering</div>
      <h2 data-i18n="openPortal">Portal öffnen</h2>
      <div class="field"><label data-i18n="language">Sprache</label><select id="langSelectLogin" class="lang-select"><option value="de">DE - Deutsch</option><option value="en">EN - English</option><option value="es">ES - Espanol</option><option value="zh">ZH - 中文</option></select></div>
      <div class="field"><label data-i18n="demoRole">Demo-Rolle</label><select id="loginRole"><option value="customer">Customer</option><option value="clarifier">Clarifier</option><option value="fieldservice">Fieldservice</option><option value="admin" selected>Admin</option></select></div>
      <div class="field"><label data-i18n="email">E-Mail</label><input id="loginEmail" type="email" value="patrick@dietz-engineering.com"></div>
      <button class="btn btn-primary" style="width:100%" data-i18n="loginButton">Einloggen</button>
      <p class="muted" data-i18n="authHint">Später: Supabase Auth mit Magic Link oder Passwort, Organisationszuordnung und Rollen per RLS.</p>
    </form>
  </div>
</div>

<div id="app" class="app hidden" data-customer-care-portal data-pm-tool-design>
  <aside class="side">
    <div class="brand-logo"><div class="brand-mark">D</div><div><div class="brand-name">DIETZ</div><div class="brand-system">Support Portal</div></div></div>
    <nav id="nav" class="nav"></nav>
    <div id="userbox" class="userbox"></div>
    <p class="muted" style="font-size:12px;margin-top:18px">Customer Care · lokale Demo · Supabase-ready<br>Telegram-Kanal: Customer Care Alerts</p>
  </aside>
  <main class="main">
    <div class="topbar">
      <div><div class="kicker">DIETZ // Customer Care</div><div id="pageTitle" class="title">Dashboard</div><div id="pageSub" class="subtitle">Tickets, KI-Triage, Eskalationen und Serviceverlauf in einer klaren Arbeitsfläche.</div></div>
      <div class="row"><select id="langSelect" class="lang-select"><option value="de">DE</option><option value="en">EN</option><option value="es">ES</option><option value="zh">ZH</option></select><button class="btn btn-primary" onclick="openTicketDialog()" data-action-new-ticket>+ Ticket erfassen</button><button class="btn btn-soft" onclick="exportSupportData()" data-action-export>Export</button><button class="btn btn-soft" onclick="logout()" data-action-logout>Logout</button></div>
    </div>
    <section id="view"></section>
  </main>
  <nav id="bottomNav" class="bottom-nav"></nav>
</div>
<div id="dialogRoot"></div>
<div id="toast" class="toast hidden"></div>

