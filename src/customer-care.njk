ing:42px}.brand-pane .brand-system,.brand-pane .muted{color:#cbd5e1}.brand-pane h1{font-size:42px;line-height:1.04;letter-spacing:-.05em;margin:30px 0 12px}.login-form{padding:42px}.notice{border-left:5px solid var(--warn);background:#fffbeb;padding:13px;border-radius:13px;color:#78350f}.app{min-height:100vh;display:grid;grid-template-columns:292px 1fr}.side{background:rgba(0,0,0,.84);backdrop-filter:saturate(180%) blur(22px);color:#e5e7eb;padding:22px;position:sticky;top:0;height:100vh;overflow:auto}.side .brand-system{color:#94a3b8}.nav{display:grid;gap:7px;margin-top:24px}.nav button{width:100%;text-align:left;background:transparent;color:#cbd5e1;padding:11px;border-radius:12px;font-weight:750}.nav button.active,.nav button:hover{background:color-mix(in srgb,var(--accent) 24%,#111827);color:#fff;outline:1px solid color-mix(in srgb,var(--accent) 65%,transparent)}.userbox{margin-top:22px;padding:13px;border:1px solid #334155;border-radius:16px;background:#0f172a}.main{padding:24px 28px 92px}.topbar{display:flex;justify-content:space-between;gap:16px;align-items:center;margin-bottom:22px;background:var(--glass);backdrop-filter:saturate(180%) blur(22px);border:1px solid rgba(255,255,255,.68);border-radius:26px;padding:18px 20px;box-shadow:0 20px 55px #0f172a12}.kicker{font-size:12px;text-transform:uppercase;letter-spacing:.16em;color:var(--accent);font-weight:900}.title{font-size:34px;font-weight:750;letter-spacing:-.04em;line-height:1.06;margin:2px 0}.subtitle{color:var(--muted)}.card{background:rgba(255,255,255,.9);border:1px solid rgba(219,227,234,.82);border-radius:var(--radius);padding:20px;box-shadow:3px 5px 30px rgba(0,0,0,.09)}.dietz-panel{border:1.5px solid color-mix(in srgb,var(--accent) 32%,var(--line));background:linear-gradient(180deg,rgba(255,255,255,.94),rgba(255,255,255,.76))}.kpis{grid-template-columns:repeat(4,minmax(0,1fr))}.metric{font-size:28px;font-weight:900}.pill{display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:5px 9px;font-size:12px;font-weight:850;background:#e2e8f0;white-space:nowrap}.pill.ok{background:#dcfce7;color:#166534}.pill.warn{background:#fef3c7;color:#92400e}.pill.danger{background:#fee2e2;color:#991b1b}.pill.blue{background:#dbeafe;color:#1d4ed8}.pill.dark{background:#0f172a;color:#fff}.columns{display:grid;grid-template-columns:1.05fr .95fr;gap:16px}.support-grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:16px}.table{width:100%;border-collapse:collapse}.table th,.table td{padding:10px;border-bottom:1px solid var(--line);text-align:left;vertical-align:top}.table th{font-size:12px;text-transform:uppercase;color:#64748b;letter-spacing:.08em}.ticket-row{cursor:pointer}.ticket-row.active,.ticket-row:hover{background:#f8fafc}.tabs{display:flex;gap:8px;flex-wrap:wrap;margin:10px 0 16px}.tabs button{background:#e2e8f0;border-radius:999px;padding:8px 11px}.tabs button.active{background:#0f172a;color:#fff}.timeline{display:grid;gap:10px}.event{border:1px solid var(--line);border-radius:14px;padding:12px;background:#fff}.chatlog{display:grid;gap:10px;max-height:360px;overflow:auto;padding-right:4px}.bubble{border-radius:16px;padding:11px 13px;line-height:1.45}.bubble.customer{background:#e0f2fe}.bubble.agent{background:#f1f5f9}.bubble.ai{background:#ecfdf5;border:1px solid #bbf7d0}.recommendations{margin:10px 0 0;padding-left:20px}.recommendations li{margin:6px 0}.role-matrix{grid-template-columns:repeat(4,minmax(0,1fr))}.supabase-schema{grid-template-columns:repeat(3,minmax(0,1fr))}.schema-chip{font-family:var(--mono);font-size:12px;background:#0f172a;color:#e5e7eb;border-radius:999px;padding:8px 10px;display:inline-flex}.dialog-backdrop{position:fixed;inset:0;background:#0f172a70;display:grid;place-items:center;padding:18px;z-index:30}.dialog{width:min(760px,100%);max-height:90vh;overflow:auto;background:#fff;border-radius:24px;padding:22px}.toast{position:fixed;right:22px;bottom:24px;background:#0f172a;color:#fff;border-radius:14px;padding:12px 16px;z-index:50}.bot