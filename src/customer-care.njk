function loadData(){try{return JSON.parse(localStorage.getItem(STORAGE_KEY))||seedData()}catch{return seedData()}}
function save(){localStorage.setItem(STORAGE_KEY,JSON.stringify(state.data))}
function currentUser(){return state.data.users.find(u=>u.role===state.role)||state.data.users[0]}
function roleLabel(role){return t(`role_${role}`)}
function statusLabel(status){return t(`status_${status}`)}
function urgencyLabel(urgency){return t(`urgency_${urgency}`)}
function can(cap){const role=ROLES[state.role];return role.can.includes('all')||role.can.includes(cap)}
function pill(text,c='blue'){return`<span class="pill ${c}">${text}</span>`}
function statusPill(code){return pill(statusLabel(code),cls(code))}
function urgencyPill(code){return pill(urgencyLabel(code),cls(code))}
function cls(v){return v==='production_stop'||v==='safety_risk'||v==='customer_requests_human'?'danger':v==='high'||v==='clarification_needed'?'warn':v==='resolved'||v==='closed'?'ok':'blue'}
function toast(text){const node=document.getElementById('toast');node.textContent=text;node.classList.remove('hidden');setTimeout(()=>node.classList.add('hidden'),2600)}
function setView(view){state.view=view;render()}
function setLang(lang){state.lang=lang;localStorage.setItem(LANG_KEY,lang);document.documentElement.lang=lang;syncLanguageControls();applyStaticTranslations();render()}
function syncLanguageControls(){['langSelect','langSelectLogin'].forEach(id=>{const el=document.getElementById(id);if(el)el.value=state.lang})}
function applyStaticTranslations(){document.querySelectorAll('[data-i18n]').forEach(el=>{el.textContent=t(el.dataset.i18n)});const map={'[data-action-new-ticket]':'newTicket','[data-action-export]':'export','[data-action-logout]':'logout'};Object.entries(map).forEach(([selector,key])=>{const el=document.querySelector(selector);if(el)el.textContent=t(key)})}
function login(role,email){state.role=role;document.getElementById('login').classList.add('hidden');document.getElementById('app').classList.remove('hidden');render();toast(`${t('loggedInAs')} ${roleLabel(role)}`)}
function logout(){document.getElementById('app').classList.add('hidden');document.getElementById('login').classList.remove('hidden');applyStaticTranslations()}
document.getElementById('loginForm').addEventListener('submit',e=>{e.preventDefault();login(document.getElementById('loginRole').value,document.getElementById('loginEmail').value)});
document.getElementById('langSelectLogin').addEventListener('change',e=>setLang(e.target.value));
document.getElementById('langSelect').addEventListener('change',e=>setLang(e.target.value));
function renderCareNextClickHint(action){return`<p class="micro-note" data-care-next-click-hint><b>${t('nextClick')}:</b> ${action}</p>`}
function renderCareCardPurpose(purpose){return`<p class="micro-note" data-care-card-purpose><b>${t('cardPurpose')}:</b> ${purpose}</p>`}
function renderCareReviewBoundary(status,boundary,extra=''){return`<p class="notice" data-care-review-boundary>${pill(status,'warn')} ${pill(t('reviewBoundary'),'blue')} ${extra?`${extra} · `:''}${boundary}</p>`}
function renderCareCompactCard(title,status,marker,body,intro='',open=false,cardId='care-card',nextClick=t('openTickets'),purpose=t('supportSummaryPurpose')){return`<details class="card dietz-panel" data-care-compact-card data-care-card-id="${cardId}" ${marker} ${open?'open':''}><summary><span><b>${title}</b><span class="muted">${intro?` · ${intro}`:''}</span></span><span>${pill(status,'warn')} ${pill(t('compactCards'),'blue')} ${pill(t('localPreference'),'blue')}</span></summary><div class="compact-body">${renderCareNextClickHint(nextClick)}${renderCareCardPurpose(purpose)}${body}</div></details>`}
function renderShell(){document.getElementById('nav').innerHTML=VIEWS.filter(id=>id!=='settings'||can('settings')).map(id=>`<button class="${state.view===id?'active':''}" onclick="setView('${id}')">${t(id)}</button>`).join('');document.getElementById('bottomNav').innerHTML=['dashboard','tickets','triage','chat','roles'].map(id=>`<button onclick="setView('${id}')">${t(id)}</button>`).join('');const u=currentUser();document.getElementById('userbox').innerHTML=`<b>${u.name}</b><br><span class="muted">${roleLabel(u.role)} · ${u.org}</span>`}
function render(){syncLanguageControls();applyStaticTranslations();renderShell();const titleKey=`${state.view}Title`;const subKey=`${state.view}Sub`;document.getElementById('pageTitle').textContent=t(titleKey);document.getElementById('pageSub').textContent=t(subKey);document.getElementById('view').innerHTML=({dashboard:renderDashboard,tickets:renderTickets,sla:renderSla,triage:renderTriage,chat:renderChat,runbook:renderRunbook,roles:renderRoles,supabase:renderSupabase,settings:renderSettings}[state.view]||renderDashboard)()}
function filteredTickets(){if(state.role==='customer')return state.data.tickets.filter(ticket=>ticket.customer.includes('Muster'));if(state.role==='fieldservice')return state.data.tickets.filter(ticket=>ticket.assignee.includes('Fieldservice'));return state.data.tickets}
function activeTicket(){return state.data.tickets.find(ticket=>ticket.id===state.activeTicketId)||filteredTickets()[0]||state.data.tickets[0]}
function renderReviewStack(tickets,urgent){const body=`<div class="grid kpis"><button class="card" onclick="setView('tickets')" style="text-align:left"><b>${t('openTicketsMetric')}</b><div class="metric">${tickets.filter(ticket=>!['resolved','closed'].includes(ticket.status)).length}</div><span class="muted">${t('openTicketList')}</span></button><button class="card" onclick="setView('triage')" style="text-align:left"><b>${t('aiLimit')}</b><div class="metric">${state.data.settings.aiRecommendationLimit}</div><span class="muted">${t('recommendationsMax')}</span></button><button class="card" onclick="setView('chat')" style="text-align:left"><b>${t('telegramAlerts')}</b><div class="metric">${tickets.filter(ticket=>ticket.telegram).length}</div><span class="muted">${t('channel')}</span></button></div>${renderCareReviewBoundary('review_required_customer_care',t('supportSummaryBoundary'))}`;const queueBody=`${urgent.map(ticket=>`<button class="between" onclick="state.activeTicketId='${ticket.id}';setView('tickets')" style="width:100%;text-align:left;border:0;border-bottom:1px solid var(--line);background:transparent;padding:10px 0;color:inherit"><span><b>${ticket.number}</b><br><span class="muted">${ticket.title}</span></span>${urgencyPill(ticket.urgency)}</button>`).join('')||`<p class="muted">${t('noUrgent')}</p>`}${renderCareReviewBoundary('review_required_local_queue',t('supportSummaryBoundary'))}`;return`<div class="review-stack">${renderCareCompactCard(t('supportSummary'),'review_required_customer_care','data-care-review-summary',body,t('supportSummaryIntro'),true,'care-summary',t('openTickets'),t('supportSummaryPurpose'))}${renderCareCompactCard(t('todayCheck'),'review_required_local_queue','data-care-review-queue',queueBody,t('todayCheckIntro'),true,'care-queue',urgent.length?t('openFirstUrgent'):t('openTriage'),t('todayCheckPurpose'))}</div>`}
function slaMinutes(ticket){const base={production_stop:15,safety_risk:15,customer_requests_human:30,high:60,normal:240,low:480}[ticket.urgency]||240;const created=new Date(ticket.created.replace(' ','T'));const elapsed=Math.max(0,Math.round((Date.now()-created.getTime())/60000));return {base,elapsed,left:base-elapsed,ratio:Math.max(0,Math.min(100,100-(elapsed/base*100)))}}
function buildHandoffPackage(ticket){return[`Ticket: ${ticket.number}`,`Kunde: ${ticket.customer}`,`Kategorie: ${ticket.category}`,`Status: ${statusLabel(ticket.status)}`,`Dringlichkeit: ${urgencyLabel(ticket.urgency)}`,`Zusammenfassung: ${ticket.summary}`,`KI-Hinweise:`,...ticket.recommendations.slice(0,5).map((item,index)=>`${index+1}. ${item}`),`Letzte Nachrichten:`,...ticket.messages.slice(-4).map(([who,text])=>`- ${who}: ${text}`),`Review-Grenze: ${t('reviewStopCopy')}`].join('\n')}
function renderOperationalLane(tickets){const groups=[['new','Eingang'],['ai_triaged','KI / Clarifier'],['assigned','Zugewiesen'],['in_progress','In Arbeit']];return`<div class="card dietz-panel" data-care-operational-lane><div class="between"><div><div class="kicker">${t('operationalLane')}</div><h2>${t('serviceHealth')}</h2><p class="muted">${t('kanbanPurpose')}</p></div>${pill('review_required_service_lane','warn')}</div><div class="kanban">${groups.map(([status,label])=>`<div class="kanban-column"><h3>${statusLabel(status)||label}</h3>${tickets.filter(ticket=>ticket.status===status).map(ticket=>`<button class="kanban-card" onclick="state.activeTicketId='${ticket.id}';setView('tickets')"><b>${ticket.number}</b><br><span class="muted">${ticket.title}</span><br>${urgencyPill(ticket.urgency)}</button>`).join('')||`<p class="muted">${t('noUrgent')}</p>`}</div>`).join('')}</div>${renderCareReviewBoundary('review_required_service_lane',t('supportSummaryBoundary'))}</div>`}
function renderSla(){const tickets=filteredTickets().filter(ticket=>!['resolved','closed'].includes(ticket.status));return`<div class="columns"><div class="card dietz-panel"><div class="kicker">${t('slaTitle')}</div><h2>${t('criticalNow')}</h2>${tickets.map(ticket=>{const sla=slaMinutes(ticket);return`<button class="kanban-card" onclick="state.activeTicketId='${ticket.id}';setView('tickets')"><div class="between"><b>${ticket.number}</b>${urgencyPill(ticket.urgency)}</div><span class="muted">${ticket.title}</span><div class="sla-track"><span style="width:${sla.ratio}%"></span></div><p class="micro-note"><b>${t('slaRemaining')}:</b> ${sla.left} min · ${t('firstResponse')}: ${sla.base} min · ${t('breachRisk')}: ${sla.left<0?'hoch':'kontrolliert'}</p></button>`}).join('')}</div><div class="card"><h2>${t('handoffPackage')}</h2><p class="muted">${t('handoffPurpose')}</p><pre class="handoff-pack">${buildHandoffPackage(activeTicket())}</pre><button class="btn btn-primary" onclick="navigator.clipboard&&navigator.clipboard.writeText(buildHandoffPackage(activeTicket()));toast(t('copyHandoff'))">${t('copyHandoff')}</button><p class="notice">${t('reviewStopCopy')}</p></div></div>`}
function renderRunbook(){const steps=[['runbookTriage','runbookTriageCopy','triage'],['runbookField','runbookFieldCopy','tickets'],['runbookAdmin','runbookAdminCopy','supabase']];return`<div class="card dietz-panel"><div class="kicker">${t('runbookTitle')}</div><h2>${t('reviewStop')}</h2><p class="notice">${t('reviewStopCopy')}</p><div class="runbook-grid">${steps.map(([title,copy,target],index)=>`<button class="runbook-step" onclick="setView('${target}')" style="text-align:left;color:inherit"><div class="kicker">0${index+1}</div><h3>${t(title)}</h3><p class="muted">${t(copy)}</p><p>${pill(t('nextClick'),'blue')} ${target}</p></button>`).join('')}</div></div>`}
function renderDashboard(){const tickets=filteredTickets();const urgent=tickets.filter(ticket=>['production_stop','safety_risk','high','customer_requests_human'].includes(ticket.urgency));const open=tickets.filter(ticket=>!['resolved','closed'].includes(ticket.status));return`<div class="grid kpis"><div class="card"><b>${t('openTicketsMetric')}</b><div class="metric">${open.length}</div></div><div class="card"><b>${t('urgentMetric')}</b><div class="metric">${urgent.length}</div></div><div class="card"><b>${t('telegramAlerts')}</b><div class="metric">${tickets.filter(ticket=>ticket.telegram).length}</div></div><div class="card"><b>${t('aiLimit')}</b><div class="metric">${state.data.settings.aiRecommendationLimit}</div><span class="muted">${t('recommendationsMax')}</span></div></div>${renderReviewStack(tickets,urgent)}${renderOperationalLane(tickets)}<div class="columns" style="margin-top:16px"><div class="card dietz-panel"><div class="between"><div><div class="kicker">${t('queue')}</div><h2>${t('currentSupport')}</h2></div><button class="btn btn-primary" onclick="setView('tickets')">${t('openTickets')}</button></div>${renderTicketTable(tickets.slice(0,5))}</div><div class="card"><div class="kicker">${t('escalation')}</div><h2>${t('channel')}</h2><p class="muted">${t('telegramRule')}</p>${urgent.map(ticket=>`<p>${urgencyPill(ticket.urgency)} <b>${ticket.number}</b><br><span class="muted">${ticket.title}</span></p>`).join('')||`<p class="muted">${t('noUrgent')}</p>`}</div></div>`}
function renderTicketTable(tickets){return`<table class="table" data-support-ticket-table><thead><tr><th>${t('ticket')}</th><th>${t('customer')}</th><th>${t('status')}</th><th>${t('urgency')}</th><th>${t('owner')}</th></tr></thead><tbody>${tickets.map(ticket=>`<tr class="ticket-row ${activeTicket().id===ticket.id?'active':''}" onclick="state.activeTicketId='${ticket.id}';setView('tickets')"><td><b>${ticket.number}</b><br><span class="muted">${ticket.title}</span></td><td>${ticket.customer}</td><td>${statusPill(ticket.status)}</td><td>${urgencyPill(ticket.urgency)}</td><td>${ticket.assignee}</td></tr>`).join('')}</tbody></table>`}
function renderTickets(){const ticket=activeTicket();return`<div class="support-grid"><div class="card dietz-panel"><div class="between"><h2>${t('ticketsTitle')}</h2><button class="btn btn-primary" onclick="openTicketDialog()">${t('newShort')}</button></div>${renderTicketTable(filteredTickets())}</div><div class="card" data-ticket-detail><div class="between"><div><div class="kicker">${ticket.number}</div><h2>${ticket.title}</h2></div>${statusPill(ticket.status)}</div><p class="muted">${ticket.summary}</p><div class="grid kpis" style="grid-template-columns:repeat(3,minmax(0,1fr));margin:12px 0"><div>${pill(ticket.category,'blue')}</div><div>${urgencyPill(ticket.urgency)}</div><div>${pill(ticket.telegram?t('telegramOn'):t('telegramOff'),ticket.telegram?'danger':'blue')}</div></div><div class="tabs">${STATUS.map(status=>`<button class="${ticket.status===status?'active':''}" onclick="setTicketStatus('${ticket.id}','${status}')">${statusLabel(status)}</button>`).join('')}</div><h3>${t('aiAssessment')}</h3><ol class="recommendations">${ticket.recommendations.slice(0,5).map(item=>`<li>${item}</li>`).join('')}</ol><div class="row" style="margin-top:14px"><button class="btn btn-danger" onclick="escalateTelegram('${ticket.id}')">${t('telegramEscalate')}</button><button class="btn btn-soft" onclick="setView('chat')">${t('openChat')}</button><button class="btn btn-ok" onclick="setTicketStatus('${ticket.id}','resolved')">${t('markResolved')}</button></div></div></div>`}
function renderTriage(){return`<div class="columns"><form class="card dietz-panel" onsubmit="event.preventDefault();createAiTicket(this)" data-ai-triage-form><div class="kicker">Aria Customer Care</div><h2>${t('captureProblem')}</h2><div class="field"><label>${t('organization')}</label><input name="customer" required value="${t('newCustomer')}"></div><div class="field"><label>${t('category')}</label><select name="category">${CATEGORIES.map(category=>`<option>${category}</option>`).join('')}</select></div><div class="field"><label>${t('urgency')}</label><select name="urgency">${URGENCY.map(urgency=>`<option value="${urgency}">${urgencyLabel(urgency)}</option>`).join('')}</select></div><div class="field"><label>${t('problem')}</label><textarea name="summary" required placeholder="${t('problemPlaceholder')}"></textarea></div><button class="btn btn-primary">${t('prepareTicket')}</button><p class="muted">${t('aiLimitCopy')}</p></form><div class="card"><h2>${t('aiBoundaries')}</h2><p>${pill(t('recommendationsMax'),'dark')} ${pill(t('humanVisible'),'ok')} ${pill(t('contactBackend'),'warn')}</p><p class="muted">${t('aiBoundaryCopy')}</p><div class="notice">${t('aiBoundaryNotice')}</div></div></div>`}
function renderChat(){const ticket=activeTicket();return`<div class="columns"><div class="card dietz-panel"><div class="between"><div><div class="kicker">${ticket.number}</div><h2>${t('contextChat')}</h2></div>${pill(roleLabel(state.role),'dark')}</div><div class="chatlog">${ticket.messages.map(([who,text])=>`<div class="bubble ${who==='customer'?'customer':who==='ai'?'ai':'agent'}"><b>${who}</b><br>${text}</div>`).join('')}</div><form class="row" style="margin-top:12px" onsubmit="event.preventDefault();addMessage(this,'${ticket.id}')"><input name="message" style="flex:1" placeholder="${t('messagePlaceholder')}"><button class="btn btn-primary">${t('send')}</button></form></div><div class="card"><h2>${t('handoffPatrick')}</h2><p class="muted">${t('handoffCopy')}</p><button class="btn btn-danger" onclick="escalateTelegram('${ticket.id}')">Customer Care Telegram Alert</button><h3>${t('lastEvents')}</h3><div class="timeline">${state.data.events.filter(event=>event.ticket===ticket.id).map(event=>`<div class="event"><span class="mono">${event.at}</span><br><b>${event.who}</b><br>${event.text}</div>`).join('')}</div></div></div>`}
function renderRoles(){return`<div class="grid role-matrix" data-support-role-matrix>${Object.entries(ROLES).map(([id,role])=>`<div class="card"><div class="kicker">${id}</div><h2>${roleLabel(id)}</h2><p class="muted">${role.can.join(' · ')}</p></div>`).join('')}</div><div class="card" style="margin-top:16px"><h2>${t('roleLogic')}</h2><p class="muted">${t('roleLogicCopy')}</p></div>`}
function renderSupabase(){const tables=['profiles','organizations','organization_members','support_tickets','ticket_messages','ticket_events','ticket_attachments','ticket_ai_assessments','ticket_assignments','telegram_escalations','support_settings'];const functions=['support-ticket-create','support-ai-triage','support-telegram-escalate','support-message-send'];return`<div class="columns"><div class="card dietz-panel"><div class="kicker">${t('schema')}</div><h2>${t('supabaseTables')}</h2><div class="grid supabase-schema">${tables.map(table=>`<span class="schema-chip">${table}</span>`).join('')}</div></div><div class="card"><div class="kicker">${t('edgeFunctions')}</div><h2>${t('backendTasks')}</h2>${functions.map(fn=>`<p>${pill(fn,'blue')} <span class="muted">${t('planned')}</span></p>`).join('')}<p class="notice">${t('rlsBoundary')}</p></div></div>`}
function renderSettings(){return`<form class="card dietz-panel" onsubmit="event.preventDefault();saveSettings(this)"><div class="kicker">Customer Care Settings</div><h2>${t('channelsSla')}</h2><div class="field"><label>${t('telegramChannel')}</label><input name="telegramChannel" value="${state.data.settings.telegramChannel}"></div><div class="field"><label>${t('aiRecommendationsMax')}</label><input name="aiRecommendationLimit" type="number" min="1" max="5" value="${state.data.settings.aiRecommendationLimit}"></div><div class="field"><label>${t('criticalSlaMinutes')}</label><input name="slaCriticalMinutes" type="number" value="${state.data.settings.slaCriticalMinutes}"></div><button class="btn btn-primary">${t('save')}</button></form>`}
function setTicketStatus(id,status){const ticket=state.data.tickets.find(item=>item.id===id);if(!ticket)return;ticket.status=status;state.data.events.push({ticket:id,at:new Date().toISOString().slice(0,16).replace('T',' '),who:roleLabel(state.role),text:`${t('eventStatus')}: ${statusLabel(status)}.`});save();render();toast(t('statusSaved'))}
function escalateTelegram(id){const ticket=state.data.tickets.find(item=>item.id===id);if(!ticket)return;ticket.telegram=true;state.data.events.push({ticket:id,at:new Date().toISOString().slice(0,16).replace('T',' '),who:'System',text:`${t('eventTelegram')} ${state.data.settings.telegramChannel}.`});save();render();toast(t('telegramPrepared'))}
function createAiTicket(form){const fd=new FormData(form);const summary=String(fd.get('summary'));const urgency=String(fd.get('urgency'));const id=`t-${Date.now()}`;const urgent=['production_stop','safety_risk','customer_requests_human'].includes(urgency);const ticket={id,number:`CARE-2026-${1000+state.data.tickets.length+1}`,title:summary.slice(0,72)||t('newTicket'),customer:String(fd.get('customer')),contact:t('protectedContact'),category:String(fd.get('category')),status:'ai_triaged',urgency,assignee:urgent?'Fieldservice Süd':'DIETZ Clarifier',created:new Date().toISOString().slice(0,16).replace('T',' '),summary,telegram:urgent,aiConfidence:urgent ? .68 : .81,recommendations:buildRecommendations(String(fd.get('category')),urgency,summary),messages:[['customer',summary],['ai',t('aiPrepared')]]};state.data.tickets.unshift(ticket);state.activeTicketId=id;state.data.events.push({ticket:id,at:ticket.created,who:'Aria Support AI',text:urgent?t('eventTriagedUrgent'):t('eventTriaged')});save();setView('tickets');toast(t('ticketCreated'))}
function buildRecommendations(category,urgency,summary){const de=['Kurz Ursache, Änderung und betroffene Maschine dokumentieren.','Aktuellen Stand von Schaltplan, EPLAN-Version und Änderungen festhalten.','Keine vertraulichen Dateien im Chat senden, Upload erst im Portal.','Dringlichkeit nach Produktionsauswirkung und Safety-Risiko setzen.','Customer Care kann Patrick oder Fieldservice mit Kontext dazuholen.'];const en=['Document cause, change and affected machine briefly.','Record schematic status, EPLAN version and recent changes.','Do not send confidential files in chat; upload them only in the portal.','Set urgency by production impact and safety risk.','Customer Care can add Patrick or field service with context.'];const base=state.lang==='de'?de:en;if(urgency==='production_stop')base[0]=state.lang==='de'?'Produktionsstopp: sichere Situation herstellen und Rückruf/Einsatz priorisieren.':'Production stop: establish a safe situation and prioritize callback/service.';if(category.includes('Safety'))base[1]=state.lang==='de'?'Safety/CE: keine Überbrückung oder Freigabe ohne Dokumentenprüfung.':'Safety/CE: no bypass or approval without document review.';return base.slice(0,5)}
function addMessage(form,id){const msg=String(new FormData(form).get('message')||'').trim();if(!msg)return;const ticket=state.data.tickets.find(item=>item.id===id);ticket.messages.push([state.role==='customer'?'customer':'agent',msg]);state.data.events.push({ticket:id,at:new Date().toISOString().slice(0,16).replace('T',' '),who:roleLabel(state.role),text:t('eventMessage')});form.reset();save();render();toast(t('messageAdded'))}
function openTicketDialog(){document.getElementById('dialogRoot').innerHTML=`<div class="dialog-backdrop"><form class="dialog" onsubmit="event.preventDefault();createAiTicket(this);closeDialog()"><h2>${t('newTicket')}</h2><div class="field"><label>${t('organization')}</label><input name="customer" required></div><div class="field"><label>${t('category')}</label><select name="category">${CATEGORIES.map(category=>`<option>${category}</option>`).join('')}</select></div><div class="field"><label>${t('urgency')}</label><select name="urgency">${URGENCY.map(urgency=>`<option value="${urgency}">${urgencyLabel(urgency)}</option>`).join('')}</select></div><div class="field"><label>${t('problem')}</label><textarea name="summary" required></textarea></div><div class="row"><button class="btn btn-primary">${t('save')}</button><button type="button" class="btn btn-soft" onclick="closeDialog()">${t('cancel')}</button></div></form></div>`}
function closeDialog(){document.getElementById('dialogRoot').innerHTML=''}
function saveSettings(form){const fd=new FormData(form);state.data.settings.telegramChannel=String(fd.get('telegramChannel'));state.data.settings.aiRecommendationLimit=Math.min(5,Math.max(1,Number(fd.get('aiRecommendationLimit')||5)));state.data.settings.slaCriticalMinutes=Number(fd.get('slaCriticalMinutes')||15);save();toast(t('settingsSaved'))}
function exportSupportData(){const blob=new Blob([JSON.stringify(state.data,null,2)],{type:'application/json'});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download='dietz-customer-care-demo.json';a.click();URL.revokeObjectURL(url)}
syncLanguageControls();
applyStaticTranslations();
render();
</script>
</body>
</html>
