<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="robots" content="noindex,nofollow">
  <title>DIETZ Operator Antwort</title>
  <style>
    :root{
      color-scheme:dark;
      --bg:#070b13;--panel:#0f1726;--panel2:#121c2f;--text:#f7f9fc;--muted:#aeb8ce;
      --gold:#f0c36a;--gold2:#ffd985;--line:rgba(255,255,255,.14);--blue:#7aa7ff;
      --shadow:0 24px 80px rgba(0,0,0,.42);--radius:28px;
    }
    *{box-sizing:border-box} body{margin:0;min-height:100dvh;font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,sans-serif;background:radial-gradient(circle at 12% 0%,rgba(240,195,106,.18),transparent 28rem),linear-gradient(145deg,#070b13 0%,#0b1220 48%,#111827 100%);color:var(--text);line-height:1.55}
    .dietz-shell{width:min(1120px,100% - 32px);margin:0 auto;padding:22px 0 42px}
    .topbar{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:clamp(2rem,7vw,5rem)}
    .brand{display:flex;align-items:center;gap:.85rem;text-decoration:none;color:var(--text);font-weight:900;letter-spacing:.02em}.mark{width:42px;height:42px;border-radius:14px;background:linear-gradient(135deg,var(--gold),#fff1ba);color:#15100a;display:grid;place-items:center;font-weight:950;box-shadow:0 10px 30px rgba(240,195,106,.22)}
    .pill{border:1px solid var(--line);border-radius:999px;padding:.55rem .85rem;color:var(--muted);font-size:.9rem;background:rgba(255,255,255,.04)}
    .hero{display:grid;grid-template-columns:minmax(0,1fr) minmax(300px,420px);gap:1.25rem;align-items:stretch}.card{background:linear-gradient(180deg,rgba(18,28,47,.92),rgba(11,18,32,.96));border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:clamp(1.15rem,4vw,2rem)}
    .eyebrow{color:var(--gold2);font-weight:850;text-transform:uppercase;letter-spacing:.12em;font-size:.78rem;margin:0 0 .75rem}h1{font-size:clamp(2rem,6vw,4.2rem);line-height:.98;margin:.1rem 0 1rem;letter-spacing:-.045em}.lead{color:var(--muted);font-size:clamp(1rem,2vw,1.16rem);max-width:64ch;margin:0}
    .timeline{display:flex;flex-direction:column;gap:.85rem;margin-top:1.35rem;max-height:min(46dvh,520px);overflow:auto;padding-right:.15rem;overscroll-behavior:contain}.empty{border:1px dashed var(--line);border-radius:20px;padding:1rem;color:var(--muted);background:rgba(255,255,255,.03)}
    .msg{border:1px solid var(--line);border-radius:20px;padding:.85rem 1rem;background:rgba(255,255,255,.045)}.msg[data-role="customer"]{border-color:rgba(122,167,255,.38);background:rgba(122,167,255,.10)}.msg[data-role="patrick"]{border-color:rgba(240,195,106,.45);background:rgba(240,195,106,.11)}.msg-role{display:block;font-size:.78rem;color:var(--gold2);font-weight:900;text-transform:uppercase;letter-spacing:.09em;margin-bottom:.35rem}.msg[data-role="customer"] .msg-role{color:#9dbdff}.msg-text{white-space:pre-wrap;color:#eef3ff}.msg-time{display:block;margin-top:.35rem;color:var(--muted);font-size:.78rem}
    label{display:block;font-weight:850;margin:.7rem 0 .45rem}textarea{width:100%;min-height:11rem;resize:vertical;border-radius:22px;border:1px solid rgba(255,255,255,.22);background:#0b1324;color:var(--text);padding:1rem;font:inherit;outline:none}textarea:focus{border-color:var(--gold);box-shadow:0 0 0 4px rgba(240,195,106,.15)}
    button{margin-top:1rem;border:0;border-radius:999px;padding:.95rem 1.3rem;background:linear-gradient(135deg,var(--gold),var(--gold2));color:#17120a;font-weight:950;min-height:46px;box-shadow:0 16px 36px rgba(240,195,106,.25)}button:disabled{opacity:.55}.notice{padding:1rem;border-radius:18px;background:rgba(240,195,106,.12);border:1px solid rgba(240,195,106,.28);margin:1rem 0}.muted{color:var(--muted)}.hidden{display:none!important}.status{min-height:1.5rem;color:var(--muted);font-size:.92rem}
    @media(max-width:820px){.dietz-shell{width:min(100% - 24px,1120px);padding-top:16px}.topbar{align-items:flex-start}.pill{display:none}.hero{grid-template-columns:1fr}.card{border-radius:24px}.timeline{max-height:38dvh}h1{font-size:clamp(2.3rem,11vw,3.5rem)}}
  </style>
</head>
<body>
  <div class="dietz-shell" data-operator-console>
    <header class="topbar">
      <a class="brand" href="/" aria-label="Dietz Engineering"><span class="mark">D</span><span>Dietz Engineering</span></a>
      <span class="pill">Privater Operator-Kanal</span>
    </header>
    <section class="hero">
      <article class="card">
        <p class="eyebrow">Aria Livechat</p>
        <h1>Antwort an Website-Chat</h1>
        <p class="lead">Hier siehst du den aktuellen Besucher-Verlauf und kannst direkt im Website-Chat antworten.</p>
        <div id="missingNotice" class="notice hidden">Der Antwort-Link ist unvollständig. Bitte den vollständigen Telegram-Link erneut öffnen.</div>
        <div id="operatorTimeline" class="timeline" aria-live="polite"><div class="empty">Chatverlauf wird geladen …</div></div>
      </article>
      <aside class="card">
        <form id="replyForm" method="post" action="https://syngygsidzrwrnjrxlbt.supabase.co/functions/v1/assistant/operator/reply">
          <input type="hidden" name="session_id" id="sessionId">
          <input type="hidden" name="operator_token" id="operatorToken">
          <label for="message">Nachricht von Patrick</label>
          <textarea id="message" name="message" autofocus required placeholder="Antwort für den Website-Besucher ..."></textarea>
          <button id="sendButton" type="submit">Antwort senden</button>
        </form>
        <p id="operatorStatus" class="status">Bereit.</p>
        <p class="muted">Die Antwort wird in den aktuellen Website-Chat gelegt. Der Verlauf aktualisiert sich automatisch.</p>
      </aside>
    </section>
  </div>
  <script>
    const ASSISTANT_ENDPOINT = "https://syngygsidzrwrnjrxlbt.supabase.co/functions/v1/assistant";
    (() => {
      const params = new URLSearchParams(window.location.search);
      const sessionId = params.get('session_id') || '';
      const operatorToken = params.get('operator_token') || '';
      const timeline = document.getElementById('operatorTimeline');
      const status = document.getElementById('operatorStatus');
      const form = document.getElementById('replyForm');
      const messageInput = document.getElementById('message');
      const sendButton = document.getElementById('sendButton');
      let cursor = 0;
      let hasMessages = false;
      document.getElementById('sessionId').value = sessionId;
      document.getElementById('operatorToken').value = operatorToken;
      function setStatus(text){ status.textContent = text; }
      function escapeHtml(value){ return String(value || '').replace(/[&<>\"]/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[ch])); }
      function roleLabel(role){ return role === 'patrick' ? 'Patrick' : role === 'system' ? 'System' : 'Besucher'; }
      function renderMessage(item){
        if (!hasMessages) { timeline.innerHTML = ''; hasMessages = true; }
        const div = document.createElement('div');
        div.className = 'msg'; div.dataset.role = item.role || 'customer';
        const time = item.created_at ? new Date(item.created_at).toLocaleString('de-DE') : '';
        div.innerHTML = `<span class="msg-role">${roleLabel(item.role)}</span><div class="msg-text">${escapeHtml(item.message)}</div>${time ? `<span class="msg-time">${escapeHtml(time)}</span>` : ''}`;
        timeline.appendChild(div); timeline.scrollTop = timeline.scrollHeight;
      }
      async function pollOperatorTimeline(){
        if (!sessionId || !operatorToken) return;
        try {
          const qs = new URLSearchParams({ session_id: sessionId, operator_token: operatorToken, after: String(cursor) });
          const response = await fetch(`${ASSISTANT_ENDPOINT}/operator/messages?${qs}`);
          const data = await response.json().catch(() => ({}));
          if (!response.ok || !data.ok) { setStatus('Link ungültig oder abgelaufen.'); return; }
          (data.messages || []).forEach(renderMessage);
          cursor = Number(data.next || cursor);
          if (!hasMessages) timeline.innerHTML = '<div class="empty">Noch keine Besucher-Nachricht im Verlauf.</div>';
          setStatus('Verlauf aktuell.');
        } catch (error) { setStatus('Verlauf konnte gerade nicht aktualisiert werden.'); }
      }
      window.pollOperatorTimeline = pollOperatorTimeline;
      if (!sessionId || !operatorToken) {
        document.getElementById('missingNotice').classList.remove('hidden');
        sendButton.disabled = true; setStatus('Antwort-Link unvollständig.'); return;
      }
      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const message = messageInput.value.trim();
        if (!message) return;
        sendButton.disabled = true; setStatus('Antwort wird gesendet …');
        try {
          const body = new URLSearchParams({ session_id: sessionId, operator_token: operatorToken, message });
          const response = await fetch(form.action, { method: 'POST', headers: { 'content-type': 'application/x-www-form-urlencoded', accept: 'application/json' }, body });
          const data = await response.json().catch(() => ({ ok: response.ok }));
          if (!response.ok || data.ok === false) throw new Error(data.error || 'send_failed');
          messageInput.value = ''; setStatus('Antwort wurde an den Website-Chat übergeben.');
          await pollOperatorTimeline();
        } catch (error) { setStatus('Antwort konnte nicht gesendet werden. Bitte erneut versuchen.'); }
        finally { sendButton.disabled = false; }
      });
      pollOperatorTimeline();
      setInterval(pollOperatorTimeline, 1800);
    })();
  </script>
</body>
</html>
